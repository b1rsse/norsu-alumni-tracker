{% extends 'base.html.twig' %}

{% block title %}Thank You — GTS{% endblock %}

{% block body %}
<div class="max-w-lg mx-auto text-center py-16">
    <div class="card">
        <div class="card-body py-12 px-8">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-green-100 text-green-600 mb-5">
                <i class="bi bi-check-circle text-5xl"></i>
            </div>
            <h2 class="text-2xl font-bold text-gray-800 mb-3">Thank You!</h2>
            <p class="text-gray-500 mb-8">
                Your Graduate Tracer Survey response has been successfully submitted.
                Your answers will help us improve course offerings and assess graduate employability
                at Negros Oriental State University.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <a href="{{ path('app_home') }}" class="btn-norsu"><i class="bi bi-house mr-1"></i>Back to Dashboard</a>
                <a href="{{ path('app_profile') }}" class="btn-outline-norsu"><i class="bi bi-person mr-1"></i>View Profile</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
