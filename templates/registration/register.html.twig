{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body_class %}no-navbar{% endblock %}

{% block body %}
<style>
    .signup-mobile-scene {
        min-height: 100vh;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        font-family: Sora, Manrope, sans-serif;
        background-color: #081845;
        background-image:
            linear-gradient(132deg, rgba(7, 22, 63, 0.88) 0%, rgba(12, 52, 120, 0.72) 45%, rgba(5, 132, 124, 0.62) 100%),
            url('{{ asset('images/home-hero-graduation.png') }}');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .signup-mobile-scene::before,
    .signup-mobile-scene::after {
        content: "";
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
    }

    .signup-mobile-scene::before {
        width: 360px;
        height: 360px;
        left: -180px;
        top: 55%;
        background: radial-gradient(circle at 50% 50%, rgba(94, 148, 255, 0.25), rgba(94, 148, 255, 0));
    }

    .signup-mobile-scene::after {
        width: 340px;
        height: 340px;
        right: -150px;
        bottom: -110px;
        background: radial-gradient(circle at 50% 50%, rgba(26, 70, 162, 0.34), rgba(26, 70, 162, 0));
    }

    .signup-mobile-wrap {
        width: min(560px, 100%);
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.15rem;
    }

    .signup-mobile-brand {
        text-align: center;
        color: #f8fbff;
    }

    .signup-badge {
        width: 92px;
        height: 92px;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.94);
        padding: 8px;
        margin: 0 auto 0.9rem;
        box-shadow: 0 16px 32px rgba(6, 18, 48, 0.36);
    }

    .signup-badge img {
        width: 100%;
        height: 100%;
        border-radius: 18px;
        object-fit: cover;
    }

    .signup-mobile-brand h1 {
        margin: 0;
        font-size: clamp(1.5rem, 4vw, 2.1rem);
        font-weight: 800;
    }

    .signup-mobile-brand p {
        margin: 0.45rem 0 0;
        color: rgba(232, 242, 255, 0.9);
        font-size: 1rem;
    }

    .signup-mobile-card {
        width: 100%;
        border-radius: 2rem;
        background: rgba(255, 255, 255, 0.94);
        border: 1px solid rgba(255, 255, 255, 0.52);
        box-shadow: 0 24px 44px rgba(3, 14, 44, 0.38);
        padding: 1.5rem;
        backdrop-filter: blur(2px);
        -webkit-backdrop-filter: blur(2px);
    }

    .signup-switch {
        border-radius: 1rem;
        background: #e8edf5;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.35rem;
        padding: 0.35rem;
        margin-bottom: 1.05rem;
    }

    .signup-switch-item {
        border: 0;
        border-radius: 0.8rem;
        background: transparent;
        color: #607693;
        text-decoration: none;
        text-align: center;
        font-size: 1.02rem;
        font-weight: 700;
        padding: 0.72rem 0.65rem;
        line-height: 1;
    }

    .signup-switch-item.is-active {
        background: #ffffff;
        color: #16223b;
        box-shadow: 0 6px 14px rgba(31, 47, 86, 0.18);
    }

    .signup-form .field {
        margin-bottom: 0.85rem;
    }

    .signup-input-wrap {
        position: relative;
    }

    .signup-input-wrap > i {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #8ca0bb;
    }

    .signup-input {
        width: 100%;
        height: 56px;
        border-radius: 1.2rem;
        border: 1px solid #d3dce8;
        background: #f8fbff;
        color: #122038;
        font-size: 1.05rem;
        padding: 0 1.1rem 0 3rem;
        outline: none;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .signup-input::placeholder {
        color: #8ca0bb;
        opacity: 1;
    }

    .signup-input:focus {
        border-color: #3f72da;
        box-shadow: 0 0 0 3px rgba(63, 114, 218, 0.2);
    }

    .signup-privacy {
        margin-top: 0.35rem;
        margin-bottom: 1.05rem;
        border: 1px solid #d8e2ef;
        border-radius: 0.95rem;
        background: #f8fbff;
        padding: 0.85rem;
    }

    .privacy-row {
        display: flex;
        align-items: flex-start;
        gap: 0.65rem;
        color: #5f7391;
        font-size: 0.98rem;
        line-height: 1.5;
    }

    .privacy-check {
        width: 1.2rem;
        height: 1.2rem;
        border: 1px solid #b9c6d9;
        border-radius: 0.3rem;
        margin-top: 0.15rem;
        accent-color: #1f3b88;
    }

    .privacy-link {
        border: 0;
        background: transparent;
        color: #1f4bc8;
        font-weight: 700;
        cursor: pointer;
        padding: 0;
    }

    .privacy-link:hover {
        color: #143997;
    }

    .signup-error {
        color: #b91c1c;
        font-size: 0.82rem;
        margin-top: 0.35rem;
    }

    .signup-submit-btn {
        width: 100%;
        border: 0;
        border-radius: 1.2rem;
        background: linear-gradient(100deg, #223267 0%, #1f2f61 62%, #162650 100%);
        color: #ffffff;
        font-size: 1.2rem;
        font-weight: 700;
        padding: 0.88rem 1rem;
        box-shadow: 0 14px 24px rgba(19, 33, 74, 0.28);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .signup-submit-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 18px 30px rgba(16, 28, 65, 0.34);
    }

    .signup-divider {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #8b9cb6;
        margin: 1.1rem 0 1rem;
        font-size: 1rem;
        font-weight: 700;
    }

    .signup-divider::before,
    .signup-divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background: #d8e0ec;
    }

    .signup-google-btn {
        width: 100%;
        border-radius: 1.2rem;
        border: 1px solid #d3dce8;
        background: #ffffff;
        color: #1b2740;
        font-size: 1.05rem;
        font-weight: 600;
        padding: 0.95rem 1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.7rem;
        cursor: pointer;
        opacity: 1;
        text-decoration: none;
        transition: border-color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
    }

    .signup-google-btn:hover {
        border-color: #b9c8df;
        background: #f8fbff;
        transform: translateY(-1px);
    }

    .signup-google-glyph {
        width: 1.45rem;
        height: 1.45rem;
        border-radius: 50%;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        color: #ea4335;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: Arial, sans-serif;
    }

    .signup-terms {
        margin: 1rem 0 0;
        text-align: center;
        color: #5f7391;
        font-size: 0.98rem;
        line-height: 1.45;
    }

    .signup-terms-emphasis {
        color: #405a87;
        font-weight: 600;
    }

    .signup-inline-link {
        border: 0;
        background: transparent;
        color: #405a87;
        font-weight: 600;
        padding: 0;
        cursor: pointer;
        text-decoration: none;
    }

    .signup-inline-link:hover {
        color: #2e466e;
        text-decoration: underline;
    }

    .signup-login-link {
        display: block;
        margin-top: 1.1rem;
        text-align: center;
        color: #5d7290;
        text-decoration: none;
        font-size: 1.05rem;
    }

    .signup-login-link b {
        color: #1f4bc8;
    }

    .signup-login-link:hover {
        color: #32496d;
    }

    .signup-back-home {
        color: #f3f7ff;
        text-decoration: none;
        font-weight: 600;
        font-size: 1.08rem;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.2rem 0.25rem;
    }

    .signup-back-home:hover {
        color: #ffffff;
    }

    .signup-visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    @media (max-width: 640px) {
        .signup-mobile-card {
            border-radius: 1.8rem;
            padding: 1.2rem;
        }

        .signup-badge {
            width: 84px;
            height: 84px;
            border-radius: 20px;
        }

        .signup-mobile-brand h1 {
            font-size: 1.9rem;
        }
    }
</style>

<div class="signup-mobile-scene">
    <div class="signup-mobile-wrap">
        <div class="signup-mobile-brand">
            <div class="signup-badge">
                <img src="{{ asset('images/norsu-logo.webp') }}" alt="NORSU logo">
            </div>
            <h1>NORSU Alumni Network</h1>
            <p>Join the alumni community and get connected</p>
        </div>

        <section class="signup-mobile-card" aria-label="Sign up form">
            <div class="signup-switch" role="tablist" aria-label="Authentication options">
                <a href="{{ path('app_login') }}" class="signup-switch-item" role="tab" aria-selected="false">Login</a>
                <button type="button" class="signup-switch-item is-active" role="tab" aria-selected="true">Sign Up</button>
            </div>

            {{ form_start(registrationForm, {'attr': {'class': 'signup-form'}}) }}
                <div class="field">
                    <label class="signup-visually-hidden" for="registration_form_schoolId">School ID</label>
                    <div class="signup-input-wrap">
                        <i class="bi bi-person-badge"></i>
                        {{ form_widget(registrationForm.schoolId, {'attr': {'class': 'signup-input', 'placeholder': 'School ID (optional)'}}) }}
                    </div>
                    <div class="signup-error">{{ form_errors(registrationForm.schoolId) }}</div>
                </div>

                <div class="field">
                    <label class="signup-visually-hidden" for="registration_form_firstName">First Name</label>
                    <div class="signup-input-wrap">
                        <i class="bi bi-person"></i>
                        {{ form_widget(registrationForm.firstName, {'attr': {'class': 'signup-input', 'placeholder': 'First name'}}) }}
                    </div>
                    <div class="signup-error">{{ form_errors(registrationForm.firstName) }}</div>
                </div>

                <div class="field">
                    <label class="signup-visually-hidden" for="registration_form_lastName">Last Name</label>
                    <div class="signup-input-wrap">
                        <i class="bi bi-person"></i>
                        {{ form_widget(registrationForm.lastName, {'attr': {'class': 'signup-input', 'placeholder': 'Last name'}}) }}
                    </div>
                    <div class="signup-error">{{ form_errors(registrationForm.lastName) }}</div>
                </div>

                <div class="field">
                    <label class="signup-visually-hidden" for="registration_form_email">Email Address</label>
                    <div class="signup-input-wrap">
                        <i class="bi bi-envelope"></i>
                        {{ form_widget(registrationForm.email, {'attr': {'class': 'signup-input', 'placeholder': 'you@example.com'}}) }}
                    </div>
                    <div class="signup-error">{{ form_errors(registrationForm.email) }}</div>
                </div>

                <div class="signup-privacy">
                    <label class="privacy-row" for="registration_form_dataPrivacyConsent">
                        {{ form_widget(registrationForm.dataPrivacyConsent, {'attr': {'class': 'privacy-check'}}) }}
                        <span>
                            I have read and agree to the Data Privacy Act compliance statement.
                            <button type="button" data-modal-open="privacy-notice" class="privacy-link">View Privacy Notice</button>
                        </span>
                    </label>
                    <div class="signup-error">{{ form_errors(registrationForm.dataPrivacyConsent) }}</div>
                </div>

                <button type="submit" class="signup-submit-btn">
                    <i class="bi bi-person-plus mr-1"></i>Register
                </button>

                <div class="signup-divider">OR</div>

                <a href="{{ path('app_google_start') }}" class="signup-google-btn" title="Sign up with Google">
                    <span class="signup-google-glyph">G</span>
                    Sign up with Google
                </a>

                <p class="signup-terms">
                    By creating an account, you agree to our
                    <span class="signup-terms-emphasis">Terms of Service</span>
                    and
                    <button type="button" data-modal-open="privacy-notice" class="signup-inline-link">Privacy Policy</button>.
                </p>
            {{ form_end(registrationForm) }}
        </section>

        <a href="{{ path('app_home') }}" class="signup-back-home">
            <i class="bi bi-house-fill"></i>
            Back to Home
        </a>
    </div>
</div>

<div id="privacy-notice" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/70 p-4" data-modal-overlay="privacy-notice" role="dialog" aria-modal="true" aria-labelledby="privacy-title">
    <div class="w-full max-w-xl rounded-2xl border border-amber-200 bg-white p-6 shadow-2xl">
        <div class="mb-4 flex items-start justify-between gap-4">
            <h2 id="privacy-title" class="text-lg font-bold text-blue-900">Data Privacy Act Notice (RA 10173)</h2>
            <button type="button" data-modal-close="privacy-notice" class="rounded-md border border-slate-200 px-2 py-1 text-xs font-semibold text-slate-600 hover:bg-slate-50">Close</button>
        </div>
        <div class="space-y-3 text-sm leading-6 text-slate-700">
            <p>Your personal information is collected and processed solely for alumni registration, identity verification, and related university services.</p>
            <p>The university applies reasonable organizational, physical, and technical safeguards to protect your data against unauthorized access, disclosure, or misuse.</p>
            <p>By proceeding, you confirm that the information you provide is accurate and that you consent to processing under the Data Privacy Act of 2012 (RA 10173).</p>
        </div>
        <div class="mt-5 text-right">
            <button type="button" data-modal-close="privacy-notice" class="rounded-lg border border-amber-300 bg-amber-50 px-4 py-2 text-sm font-semibold text-amber-900 hover:bg-amber-100">I Understand</button>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('[data-modal-open]').forEach(function (button) {
        button.addEventListener('click', function () {
            var modalId = button.getAttribute('data-modal-open');
            var modal = document.getElementById(modalId);
            if (modal) {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            }
        });
    });

    document.querySelectorAll('[data-modal-close]').forEach(function (button) {
        button.addEventListener('click', function () {
            var modalId = button.getAttribute('data-modal-close');
            var modal = document.getElementById(modalId);
            if (modal) {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        });
    });

    document.querySelectorAll('[data-modal-overlay]').forEach(function (overlay) {
        overlay.addEventListener('click', function (event) {
            if (event.target !== overlay) {
                return;
            }

            overlay.classList.add('hidden');
            overlay.classList.remove('flex');
        });
    });
</script>
{% endblock %}
