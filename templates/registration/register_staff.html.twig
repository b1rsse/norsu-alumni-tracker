{% extends 'base.html.twig' %}

{% block title %}Staff Registration{% endblock %}

{% block body_class %}no-navbar{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-container">
        <div class="card auth-card">
            <div class="card-body p-6">
                <div class="text-center mb-4">
                    <img src="{{ asset('images/norsu-logo.webp') }}" alt="NORSU" class="auth-logo mb-2">
                    <h2 class="text-xl font-bold text-gray-800 mb-1"><i class="bi bi-person-badge-fill mr-2" style="color:#0284C7"></i>Staff Registration</h2>
                    <p class="text-gray-500 text-sm">Create your staff account</p>
                </div>

                <div class="mb-3 text-center">
                    <span class="inline-flex items-center gap-1 rounded-full px-4 py-1.5 text-sm font-medium" style="background:#E0F2FE;color:#0284C7">
                        <i class="bi bi-person-badge-fill"></i>Staff Account
                    </span>
                </div>

                {{ form_start(registrationForm) }}
                    <div class="grid grid-cols-2 gap-3 mb-3">
                        <div>
                            <label class="form-label font-semibold">First Name</label>
                            <div class="auth-input-icon">
                                <i class="bi bi-person"></i>
                                {{ form_widget(registrationForm.firstName, {'attr': {'placeholder': 'First name'}}) }}
                            </div>
                            {{ form_errors(registrationForm.firstName) }}
                        </div>
                        <div>
                            <label class="form-label font-semibold">Last Name</label>
                            <div class="auth-input-icon">
                                <i class="bi bi-person"></i>
                                {{ form_widget(registrationForm.lastName, {'attr': {'placeholder': 'Last name'}}) }}
                            </div>
                            {{ form_errors(registrationForm.lastName) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-semibold">Email Address</label>
                        <div class="auth-input-icon">
                            <i class="bi bi-envelope"></i>
                            {{ form_widget(registrationForm.email, {'attr': {'placeholder': 'you@example.com'}}) }}
                        </div>
                        {{ form_errors(registrationForm.email) }}
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-semibold">Department <span class="text-gray-400 font-normal">(Optional)</span></label>
                        <div class="auth-input-icon">
                            <i class="bi bi-building"></i>
                            {{ form_widget(registrationForm.department, {'attr': {'placeholder': 'e.g. College of Arts & Sciences'}}) }}
                        </div>
                        {{ form_errors(registrationForm.department) }}
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-semibold">Password</label>
                        <div class="auth-input-icon">
                            <i class="bi bi-lock"></i>
                            {{ form_widget(registrationForm.plainPassword.first, {'attr': {'placeholder': 'Create a password', 'class': 'password-has-toggle'}}) }}
                            <button type="button" class="password-toggle-btn" tabindex="-1"><i class="bi bi-eye-slash"></i></button>
                        </div>
                        {{ form_errors(registrationForm.plainPassword.first) }}
                        <div class="text-xs text-gray-500 mt-1">Min 8 chars, with uppercase, lowercase, number, and special character.</div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label font-semibold">Confirm Password</label>
                        <div class="auth-input-icon">
                            <i class="bi bi-shield-lock"></i>
                            {{ form_widget(registrationForm.plainPassword.second, {'attr': {'placeholder': 'Confirm your password', 'class': 'password-has-toggle'}}) }}
                            <button type="button" class="password-toggle-btn" tabindex="-1"><i class="bi bi-eye-slash"></i></button>
                        </div>
                        {{ form_errors(registrationForm.plainPassword) }}
                    </div>

                    <div class="mb-3">
                        <button type="submit" class="btn-norsu w-full py-2.5 text-base">
                            <i class="bi bi-person-plus mr-1"></i>Create Staff Account
                        </button>
                    </div>

                    <div class="text-center">
                        <p class="mb-1 text-gray-500 text-sm">Not a staff member? <a href="{{ path('app_register') }}" class="auth-link">Register as Alumni</a></p>
                        <p class="mb-0 text-gray-500 text-sm">Already have an account? <a href="{{ path('app_login') }}" class="auth-link">Log in here</a></p>
                    </div>
                {{ form_end(registrationForm) }}
            </div>
        </div>

        <div class="auth-footer mt-3">
            <p class="mb-0">&copy; {{ 'now'|date('Y') }} Negros Oriental State University</p>
        </div>
    </div>
</div>
{% endblock %}
