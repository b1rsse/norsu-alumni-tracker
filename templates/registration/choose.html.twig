{% extends 'base.html.twig' %}

{% block title %}Register — Choose Account Type{% endblock %}

{% block body_class %}no-navbar{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-container" style="max-width:560px">
        <div class="card auth-card">
            <div class="card-body py-8 px-6">
                <div class="text-center mb-4">
                    <img src="{{ asset('images/norsu-logo.webp') }}" alt="NORSU" class="auth-logo mb-2">
                    <h2 class="text-xl font-bold text-gray-800 mb-1">Create an Account</h2>
                    <p class="text-gray-500 text-sm">Choose your account type to get started</p>
                </div>

                <div class="flex justify-center gap-3 mb-4">
                    {# ── Alumni Card ── #}
                    <a href="{{ path('app_register') }}" class="no-underline">
                        <div class="card border-0 shadow-sm text-center p-5 rounded-2xl hover:shadow-md hover:-translate-y-0.5 transition-all cursor-pointer w-48">
                            <div class="mb-3">
                                <div class="inline-flex items-center justify-center rounded-full w-16 h-16" style="background:#D1FAE5">
                                    <i class="bi bi-book-fill text-3xl" style="color:#059669"></i>
                                </div>
                            </div>
                            <h5 class="font-bold mb-1 text-gray-800">Alumni</h5>
                            <p class="text-gray-500 text-sm mb-0">NORSU graduate</p>
                        </div>
                    </a>
                </div>

                <div class="text-center">
                    <p class="mb-0 text-gray-500 text-sm">Already have an account? <a href="{{ path('app_login') }}" class="auth-link">Log in here</a></p>
                </div>
            </div>
        </div>

        <div class="auth-footer mt-3">
            <p class="mb-0">&copy; {{ 'now'|date('Y') }} Negros Oriental State University</p>
        </div>
    </div>
</div>
{% endblock %}
