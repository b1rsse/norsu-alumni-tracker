{% extends 'base.html.twig' %}

{% block title %}My Profile{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-person-circle me-2"></i>Administrator Profile</h4>
    <a href="{{ path('app_profile_edit') }}" class="btn btn-norsu"><i class="bi bi-pencil-square me-1"></i>Edit Profile</a>
</div>

<div class="row g-4">
    {# ── Profile Card ── #}
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body py-5">
                <div class="mx-auto mb-3" style="width:90px;height:90px;border-radius:50%;background:linear-gradient(135deg,var(--norsu-blue),var(--norsu-green));display:flex;align-items:center;justify-content:center;font-size:2.2rem;font-weight:700;color:#fff">
                    {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                </div>
                <h5 class="fw-bold mb-1">{{ user.fullName }}</h5>
                <p class="text-muted mb-2">{{ user.email }}</p>
                {% if 'ROLE_ADMIN' in user.roles %}
                    <span class="badge bg-success"><i class="bi bi-shield-check me-1"></i>Administrator</span>
                {% else %}
                    <span class="badge bg-primary"><i class="bi bi-person me-1"></i>User</span>
                {% endif %}
            </div>
        </div>
    </div>

    {# ── Account Details ── #}
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-info-circle me-1"></i> Account Information</div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tbody>
                        <tr>
                            <td class="text-muted" style="width:200px"><i class="bi bi-person me-2"></i>First Name</td>
                            <td class="fw-semibold">{{ user.firstName }}</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i class="bi bi-person me-2"></i>Last Name</td>
                            <td class="fw-semibold">{{ user.lastName }}</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i class="bi bi-envelope me-2"></i>Email Address</td>
                            <td class="fw-semibold">{{ user.email }}</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i class="bi bi-shield me-2"></i>Role</td>
                            <td>
                                {% for role in user.roles %}
                                    {% if role == 'ROLE_ADMIN' %}
                                        <span class="badge bg-success me-1">Admin</span>
                                    {% elseif role == 'ROLE_USER' %}
                                        <span class="badge bg-primary me-1">User</span>
                                    {% else %}
                                        <span class="badge bg-secondary me-1">{{ role }}</span>
                                    {% endif %}
                                {% endfor %}
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i class="bi bi-check-circle me-2"></i>Account Status</td>
                            <td>
                                {% if user.accountStatus == 'active' %}
                                    <span class="badge bg-success">Active</span>
                                {% elseif user.accountStatus == 'pending' %}
                                    <span class="badge bg-warning text-dark">Pending</span>
                                {% else %}
                                    <span class="badge bg-danger">Inactive</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i class="bi bi-calendar-event me-2"></i>Date Registered</td>
                            <td class="fw-semibold">{{ user.dateRegistered|date('F d, Y \\a\\t h:i A') }}</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i class="bi bi-clock-history me-2"></i>Last Login</td>
                            <td class="fw-semibold">
                                {% if user.lastLogin %}
                                    {{ user.lastLogin|date('F d, Y \\a\\t h:i A') }}
                                {% else %}
                                    <span class="text-muted">Never</span>
                                {% endif %}
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        {# ── Security Section ── #}
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-lock me-1"></i> Security</div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 fw-semibold">Password</p>
                        <p class="text-muted mb-0 small">Last changed at registration. Update your password regularly for security.</p>
                    </div>
                    <a href="{{ path('app_profile_edit') }}" class="btn btn-outline-norsu btn-sm"><i class="bi bi-key me-1"></i>Change Password</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
