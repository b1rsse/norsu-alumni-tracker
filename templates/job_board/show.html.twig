{% extends 'base.html.twig' %}

{% block title %}{{ job.title }} — Job Board{% endblock %}

{% block body %}
<div class="flex justify-between items-center mb-3">
    <a href="{{ path('job_board_index') }}" class="btn-outline-norsu btn-sm"><i class="bi bi-arrow-left mr-1"></i>Back to Jobs</a>
    {% if is_granted('ROLE_STAFF') %}
        <div class="flex gap-1">
            <a href="{{ path('job_board_edit', {id: job.id}) }}" class="btn-warning btn-sm"><i class="bi bi-pencil mr-1"></i>Edit</a>
            <form method="post" action="{{ path('job_board_delete', {id: job.id}) }}" class="inline"
                  onsubmit="return confirm('Delete this job posting?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ job.id) }}">
                <button class="btn-danger btn-sm"><i class="bi bi-trash mr-1"></i>Delete</button>
            </form>
        </div>
    {% endif %}
</div>

<div class="card">
    <div class="card-body">
        <div class="flex flex-col md:flex-row justify-between items-start gap-3 mb-4">
            <div>
                <h3 class="font-bold mb-1">{{ job.title }}</h3>
                <div class="text-lg text-gray-600 mb-2">{{ job.companyName }}</div>
                <div class="flex flex-wrap gap-2 text-sm text-gray-500">
                    {% if job.location %}<span><i class="bi bi-geo-alt mr-1"></i>{{ job.location }}</span>{% endif %}
                    <span class="badge badge-info">{{ job.employmentType }}</span>
                    {% if job.isActive %}
                        <span class="badge badge-employed">Active</span>
                    {% else %}
                        <span class="badge badge-secondary">Closed</span>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Info boxes #}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
            {% if job.salaryRange %}
            <div class="border rounded-lg p-3 text-center">
                <div class="text-gray-500 text-xs uppercase mb-1">Salary</div>
                <div class="font-bold text-sm">{{ job.salaryRange }}</div>
            </div>
            {% endif %}
            {% if job.industry %}
            <div class="border rounded-lg p-3 text-center">
                <div class="text-gray-500 text-xs uppercase mb-1">Industry</div>
                <div class="font-bold text-sm">{{ job.industry }}</div>
            </div>
            {% endif %}
            {% if job.relatedCourse %}
            <div class="border rounded-lg p-3 text-center">
                <div class="text-gray-500 text-xs uppercase mb-1">Target Course</div>
                <div class="font-bold text-sm">{{ job.relatedCourse }}</div>
            </div>
            {% endif %}
            {% if job.deadline %}
            <div class="border rounded-lg p-3 text-center {{ job.deadline < date() ? 'border-red-300 bg-red-50' : '' }}">
                <div class="text-gray-500 text-xs uppercase mb-1">Deadline</div>
                <div class="font-bold text-sm {{ job.deadline < date() ? 'text-red-500' : '' }}">{{ job.deadline|date('M d, Y') }}</div>
            </div>
            {% endif %}
        </div>

        {# Description #}
        {% if job.description %}
        <div class="mb-4">
            <h6 class="font-bold mb-2"><i class="bi bi-text-paragraph mr-1"></i>Description</h6>
            <div style="white-space: pre-line;">{{ job.description }}</div>
        </div>
        {% endif %}

        {# Requirements #}
        {% if job.requirements %}
        <div class="mb-4">
            <h6 class="font-bold mb-2"><i class="bi bi-list-check mr-1"></i>Requirements</h6>
            <div style="white-space: pre-line;">{{ job.requirements }}</div>
        </div>
        {% endif %}

        {# Action buttons #}
        <hr class="my-4 border-gray-200">
        <div class="flex flex-wrap gap-2">
            {% if job.applicationLink %}
                <a href="{{ job.applicationLink }}" target="_blank" class="btn-norsu"><i class="bi bi-box-arrow-up-right mr-1"></i>Apply Now</a>
            {% endif %}
            {% if job.contactEmail %}
                <a href="mailto:{{ job.contactEmail }}" class="btn-outline-norsu"><i class="bi bi-envelope mr-1"></i>{{ job.contactEmail }}</a>
            {% endif %}
        </div>

        <div class="text-gray-500 text-xs mt-3">
            Posted on {{ job.datePosted|date('F d, Y') }}
            {% if job.postedBy %} by {{ job.postedBy.fullName }}{% endif %}
        </div>
    </div>
</div>
{% endblock %}
