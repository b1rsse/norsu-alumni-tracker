{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
<div class="flex justify-between items-center mb-3">
    <h4 class="font-bold mb-0">{{ title }}</h4>
    <a href="{{ path('job_board_manage') }}" class="btn-outline-norsu"><i class="bi bi-arrow-left mr-1"></i>Back</a>
</div>

<div class="card">
    <div class="card-header-norsu"><i class="bi bi-briefcase-fill mr-2"></i>Job Posting Details</div>
    <div class="card-body">
        {{ form_start(form) }}
            <div class="grid grid-cols-1 md:grid-cols-12 gap-3">
                <div class="md:col-span-6">{{ form_row(form.title) }}</div>
                <div class="md:col-span-6">{{ form_row(form.companyName) }}</div>
                <div class="md:col-span-4">{{ form_row(form.location) }}</div>
                <div class="md:col-span-4">{{ form_row(form.employmentType) }}</div>
                <div class="md:col-span-4">{{ form_row(form.salaryRange) }}</div>
                <div class="md:col-span-4">{{ form_row(form.industry) }}</div>
                <div class="md:col-span-4">{{ form_row(form.relatedCourse) }}</div>
                <div class="md:col-span-12">{{ form_row(form.description) }}</div>
                <div class="md:col-span-12">{{ form_row(form.requirements) }}</div>
                <div class="md:col-span-6">{{ form_row(form.contactEmail) }}</div>
                <div class="md:col-span-6">{{ form_row(form.applicationLink) }}</div>
                <div class="md:col-span-4">{{ form_row(form.deadline) }}</div>
                <div class="md:col-span-4">{{ form_row(form.isActive) }}</div>
            </div>
            <div class="mt-4 flex gap-2">
                <button type="submit" class="btn-norsu"><i class="bi bi-check-lg mr-1"></i>Save Job Posting</button>
                <a href="{{ path('job_board_manage') }}" class="btn-secondary">Cancel</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
