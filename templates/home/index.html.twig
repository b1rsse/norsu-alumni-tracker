{% extends 'base.html.twig' %}

{% block title %}Dashboard — NORSU Alumni Tracker{% endblock %}

{% block body %}
{# ── Welcome Banner ── #}
<div class="welcome-banner">
    <div class="banner-main">
        <div class="d-flex justify-content-between align-items-center flex-wrap">
            <div class="d-flex align-items-center gap-3">
                <div class="user-avatar">
                    {{ app.user.firstName|first }}{{ app.user.lastName|first }}
                </div>
                <div>
                    <h2 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h2>
                    <p class="mb-0 mt-1">Welcome back, <strong>{{ app.user.firstName }} {{ app.user.lastName }}</strong>! Here's your alumni system overview.</p>
                </div>
            </div>
            <div class="mt-3 mt-md-0 d-flex gap-2">
                <a href="{{ path('alumni_create') }}" class="btn btn-light fw-semibold"><i class="bi bi-person-plus-fill me-1"></i>Add Alumni</a>
                {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('report_index') }}" class="btn btn-outline-light fw-semibold"><i class="bi bi-graph-up me-1"></i>Reports</a>
                {% endif %}
            </div>
        </div>
    </div>
    <div class="banner-bottom">
        <span><i class="bi bi-calendar3 me-1"></i>{{ 'now'|date('F d, Y') }}</span>
        <span><i class="bi bi-clock me-1"></i>{{ 'now'|date('h:i A') }}</span>
        {% if is_granted('ROLE_ADMIN') %}
            <span class="badge bg-white text-primary" style="font-size:0.7rem"><i class="bi bi-shield-check me-1"></i>Administrator</span>
        {% endif %}
        <span class="ms-auto"><i class="bi bi-people me-1"></i>{{ totalAlumni }} total alumni</span>
    </div>
</div>

{# ── Stat Cards ── #}
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#E0F2FE">
                    <i class="bi bi-people-fill fs-4" style="color:#0284C7"></i>
                </div>
                <div>
                    <div class="stat-value">{{ totalAlumni }}</div>
                    <div class="stat-label">Total Alumni</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#D1FAE5">
                    <i class="bi bi-briefcase-fill fs-4" style="color:#059669"></i>
                </div>
                <div>
                    <div class="stat-value">{{ employed }}</div>
                    <div class="stat-label">Employed</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#FEF3C7">
                    <i class="bi bi-shop fs-4" style="color:#D97706"></i>
                </div>
                <div>
                    <div class="stat-value">{{ selfEmployed }}</div>
                    <div class="stat-label">Self-Employed</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#FEE2E2">
                    <i class="bi bi-search fs-4" style="color:#DC2626"></i>
                </div>
                <div>
                    <div class="stat-value">{{ unemployed }}</div>
                    <div class="stat-label">Unemployed</div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Employment Rate + Quick Actions ── #}
<div class="row g-3 mb-4">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body text-center py-4">
                <h6 class="text-muted fw-semibold mb-3">Employment Rate</h6>
                <div style="position:relative;width:120px;height:120px;margin:0 auto;">
                    <svg viewBox="0 0 36 36" style="width:120px;height:120px">
                        <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                              fill="none" stroke="#e5e7eb" stroke-width="3"/>
                        <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                              fill="none" stroke="#1E40AF" stroke-width="3"
                              stroke-dasharray="{{ employmentRate }}, 100"
                              stroke-linecap="round"/>
                    </svg>
                    <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center">
                        <span style="font-size:1.5rem;font-weight:800;color:#1E40AF">{{ employmentRate }}%</span>
                    </div>
                </div>
                <p class="text-muted mt-2 mb-0 small">of alumni are employed</p>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header bg-white border-bottom fw-semibold">
                <i class="bi bi-lightning-fill text-warning me-1"></i> Quick Actions
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6 col-md-3">
                        <a href="{{ path('alumni_create') }}" class="quick-action-card">
                            <div class="action-icon" style="background:#D1FAE5"><i class="bi bi-person-plus-fill fs-4" style="color:#059669"></i></div>
                            <div class="fw-semibold small">Add Alumni</div>
                        </a>
                    </div>
                    <div class="col-6 col-md-3">
                        <a href="{{ path('alumni_index') }}" class="quick-action-card">
                            <div class="action-icon" style="background:#E0F2FE"><i class="bi bi-search fs-4" style="color:#0284C7"></i></div>
                            <div class="fw-semibold small">Search Alumni</div>
                        </a>
                    </div>
                    <div class="col-6 col-md-3">
                        <a href="{{ path('report_index') }}" class="quick-action-card">
                            <div class="action-icon" style="background:#FEF3C7"><i class="bi bi-file-earmark-bar-graph fs-4" style="color:#D97706"></i></div>
                            <div class="fw-semibold small">Reports</div>
                        </a>
                    </div>
                    <div class="col-6 col-md-3">
                        <a href="{{ path('announcement_index') }}" class="quick-action-card">
                            <div class="action-icon" style="background:#EDE9FE"><i class="bi bi-megaphone-fill fs-4" style="color:#7C3AED"></i></div>
                            <div class="fw-semibold small">Announcements</div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Recent Alumni + Course Distribution ── #}
<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center">
                <span class="fw-semibold"><i class="bi bi-clock-history me-1"></i> Recently Added Alumni</span>
                <a href="{{ path('alumni_index') }}" class="btn btn-sm btn-outline-norsu">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Name</th>
                                <th>Course</th>
                                <th>Year</th>
                                <th>Status</th>
                                <th class="text-end pe-3">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for alumni in recentAlumni %}
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-semibold">{{ alumni.lastName }}, {{ alumni.firstName }}</div>
                                    <small class="text-muted">{{ alumni.studentNumber }}</small>
                                </td>
                                <td>{{ alumni.course }}</td>
                                <td>{{ alumni.yearGraduated ?? 'N/A' }}</td>
                                <td>
                                    {% if alumni.employmentStatus == 'Employed' %}
                                        <span class="badge badge-employed">Employed</span>
                                    {% elseif alumni.employmentStatus == 'Unemployed' %}
                                        <span class="badge badge-unemployed">Unemployed</span>
                                    {% elseif alumni.employmentStatus == 'Self-Employed' %}
                                        <span class="badge badge-self-employed">Self-Employed</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ alumni.employmentStatus ?? 'N/A' }}</span>
                                    {% endif %}
                                </td>
                                <td class="text-end pe-3">
                                    <a href="{{ path('alumni_show', {id: alumni.id}) }}" class="btn btn-sm btn-outline-norsu">View</a>
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">No alumni records yet. <a href="{{ path('alumni_create') }}">Add the first one</a>.</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header bg-white border-bottom fw-semibold">
                <i class="bi bi-mortarboard-fill me-1"></i> Top Courses
            </div>
            <div class="card-body">
                {% if courseStats|length > 0 %}
                    {% for stat in courseStats %}
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="fw-semibold small">{{ stat.course }}</span>
                            <span class="small text-muted">{{ stat.total }} alumni</span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            {% set maxTotal = courseStats[0].total %}
                            <div class="progress-bar" role="progressbar"
                                 style="width: {{ (stat.total / maxTotal * 100)|round }}%; background-color: var(--norsu-blue);">
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <p class="text-muted text-center py-3 mb-0">No course data available yet.</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# ── System Overview ── #}
<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-white border-bottom fw-semibold">
                <i class="bi bi-info-circle me-1"></i> System Overview
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-4">
                        <div class="fs-3 fw-bold" style="color:var(--norsu-blue)">{{ totalUsers }}</div>
                        <small class="text-muted">Registered Users</small>
                    </div>
                    <div class="col-4">
                        <div class="fs-3 fw-bold" style="color:var(--norsu-green)">{{ courseStats|length }}</div>
                        <small class="text-muted">Courses</small>
                    </div>
                    <div class="col-4">
                        <div class="fs-3 fw-bold" style="color:#7C3AED">{{ totalAlumni }}</div>
                        <small class="text-muted">Total Records</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-white border-bottom fw-semibold">
                <i class="bi bi-bar-chart-fill me-1"></i> Employment Breakdown
            </div>
            <div class="card-body">
                {% set others = totalAlumni - employed - unemployed - selfEmployed %}
                <div class="d-flex gap-2 flex-wrap">
                    <span class="badge badge-employed p-2"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem"></i> Employed: {{ employed }}</span>
                    <span class="badge badge-self-employed p-2"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem"></i> Self-Employed: {{ selfEmployed }}</span>
                    <span class="badge badge-unemployed p-2"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem"></i> Unemployed: {{ unemployed }}</span>
                    {% if others > 0 %}
                    <span class="badge bg-secondary p-2"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem"></i> Other: {{ others }}</span>
                    {% endif %}
                </div>
                {% if totalAlumni > 0 %}
                <div class="progress mt-3" style="height: 12px; border-radius: 6px;">
                    <div class="progress-bar badge-employed" style="width:{{ (employed/totalAlumni*100)|round }}%"></div>
                    <div class="progress-bar badge-self-employed" style="width:{{ (selfEmployed/totalAlumni*100)|round }}%"></div>
                    <div class="progress-bar badge-unemployed" style="width:{{ (unemployed/totalAlumni*100)|round }}%"></div>
                    {% if others > 0 %}
                    <div class="progress-bar bg-secondary" style="width:{{ (others/totalAlumni*100)|round }}%"></div>
                    {% endif %}
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# ── Footer ── #}
<footer class="footer-norsu rounded-top" style="margin-left:-1.5rem;margin-right:-1.5rem;margin-bottom:-1.5rem;padding-left:2rem;padding-right:2rem;">
    <div class="d-flex justify-content-between align-items-start flex-wrap">
        <div>
            <div class="footer-brand"><img src="{{ asset('images/norsu-logo.webp') }}" alt="NORSU" style="width:24px;height:24px;border-radius:50%;object-fit:cover;vertical-align:middle" class="me-2">NORSU Alumni Tracker</div>
            <p class="mb-2 small" style="max-width:400px">Negros Oriental State University — Connecting alumni, tracking careers, and building a stronger community.</p>
            <div class="footer-social">
                <a href="#"><i class="bi bi-facebook"></i></a>
                <a href="#"><i class="bi bi-envelope-fill"></i></a>
                <a href="#"><i class="bi bi-globe2"></i></a>
            </div>
        </div>
        <div class="d-flex gap-5 mt-3 mt-md-0">
            <div>
                <h6 class="text-white fw-semibold mb-2" style="font-size:0.85rem">Quick Links</h6>
                <div class="d-flex flex-column gap-1 footer-links" style="font-size:0.85rem">
                    <a href="{{ path('alumni_index') }}">Alumni Directory</a>
                    <a href="{{ path('announcement_index') }}">Announcements</a>
                    <a href="{{ path('feedback_submit') }}">Submit Feedback</a>
                </div>
            </div>
            {% if is_granted('ROLE_ADMIN') %}
            <div>
                <h6 class="text-white fw-semibold mb-2" style="font-size:0.85rem">Administration</h6>
                <div class="d-flex flex-column gap-1 footer-links" style="font-size:0.85rem">
                    <a href="{{ path('report_index') }}">Reports</a>
                    <a href="{{ path('admin_users') }}">Manage Users</a>
                    <a href="{{ path('feedback_index') }}">View Feedback</a>
                </div>
            </div>
            {% endif %}
        </div>
    </div>
    <div class="footer-divider"></div>
    <div class="d-flex justify-content-between align-items-center flex-wrap" style="font-size:0.8rem">
        <span>&copy; {{ 'now'|date('Y') }} NORSU Alumni Tracker. All rights reserved.</span>
        <span>Negros Oriental State University, Dumaguete City</span>
    </div>
</footer>
{% endblock %}
