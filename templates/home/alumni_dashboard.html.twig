{% extends 'base.html.twig' %}

{% block title %}Alumni Dashboard | NORSU{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .norsu-header-shell {
            background-color: #eef4ff;
            background-image: linear-gradient(120deg, rgba(248, 251, 255, 0.92) 0%, rgba(239, 246, 255, 0.88) 46%, rgba(232, 249, 245, 0.84) 100%),
                              url('{{ asset('images/home-hero-graduation.png') }}');
            background-size: cover;
            background-position: center;
            border: 1px solid rgba(30, 64, 175, 0.18);
        }

        .norsu-glass-nav {
            background: rgba(255, 255, 255, 0.62);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 12px 34px rgba(15, 23, 42, 0.08);
        }

        .announcement-visual {
            position: relative;
            overflow: hidden;
        }

        .announcement-visual::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(2, 6, 23, 0.14) 8%, rgba(2, 6, 23, 0.78) 100%);
            z-index: 1;
        }

        .announcement-visual::after {
            content: '';
            position: absolute;
            inset: 12px;
            border: 1px solid rgba(255, 255, 255, 0.4);
            border-radius: 0.75rem;
            z-index: 1;
        }

        .announcement-headline {
            position: absolute;
            left: 1rem;
            right: 1rem;
            bottom: 1rem;
            z-index: 2;
        }

        .gold-action {
            background: linear-gradient(135deg, #f8d679 0%, #f1bc3a 48%, #d89f11 100%);
            border: 1px solid #d89f11;
            color: #1f2937;
            box-shadow: 0 7px 16px rgba(216, 159, 17, 0.26);
        }

        .gold-action:hover {
            filter: brightness(1.03);
            transform: translateY(-1px);
        }

        .blue-action {
            background: linear-gradient(135deg, #1d4ed8 0%, #1e40af 70%, #1e3a8a 100%);
            border: 1px solid rgba(30, 64, 175, 0.45);
            color: #ffffff;
            box-shadow: 0 8px 18px rgba(30, 64, 175, 0.28);
        }

        .blue-action:hover {
            filter: brightness(1.05);
            transform: translateY(-1px);
        }

        .job-ticker-window {
            max-height: 330px;
            overflow: hidden;
            position: relative;
        }

        .job-ticker-track {
            animation: jobs-scroll 24s linear infinite;
        }

        .job-ticker-window:hover .job-ticker-track {
            animation-play-state: paused;
        }

        @keyframes jobs-scroll {
            0% { transform: translateY(0); }
            100% { transform: translateY(-50%); }
        }

        .spotlight-card {
            background: linear-gradient(155deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 252, 240, 0.95) 100%);
            border: 1px solid rgba(217, 157, 17, 0.42);
            box-shadow: 0 12px 30px rgba(148, 110, 16, 0.17);
        }

        .spotlight-ribbon {
            background: linear-gradient(130deg, #f5c95d 0%, #e2a42b 100%);
            color: #1f2937;
        }

        @media (max-width: 767px) {
            .job-ticker-track {
                animation: none;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="space-y-6 pb-6">
    <section class="norsu-header-shell rounded-2xl p-4 sm:p-5 lg:p-6">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div class="flex items-start gap-3 sm:gap-4">
                <img src="{{ asset('images/norsu-logo.webp') }}" alt="NORSU Logo" class="h-14 w-14 rounded-full border-2 border-white shadow-lg object-cover">
                <div>
                    <p class="text-[0.68rem] sm:text-xs uppercase tracking-[0.24em] text-blue-700 font-semibold mb-1">Negros Oriental State University</p>
                    <h1 class="text-xl sm:text-2xl lg:text-3xl font-black text-slate-900 leading-tight">Office of the University Alumni Affairs</h1>
                    <p class="text-slate-600 text-sm sm:text-base mt-1">Application-first hub for announcements, opportunities, and alumni milestones.</p>
                </div>
            </div>
            <div class="flex flex-wrap gap-2 sm:gap-3">
                {% if alumni %}
                    <a href="{{ path('alumni_edit', {id: alumni.id}) }}" class="blue-action inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold no-underline transition-all">
                        <i class="bi bi-pencil-square"></i> Update My Profile
                    </a>
                {% else %}
                    <a href="{{ path('alumni_index') }}#addAlumniSection" class="blue-action inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold no-underline transition-all" onclick="setTimeout(function(){var s=document.getElementById('addAlumniSection');if(s)s.classList.remove('hidden')},100)">
                        <i class="bi bi-person-plus-fill"></i> Submit My Alumni Record
                    </a>
                {% endif %}
                <a href="{{ path('job_board_index') }}" class="gold-action inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold no-underline transition-all">
                    <i class="bi bi-briefcase-fill"></i> Explore Careers
                </a>
            </div>
        </div>

        <div class="norsu-glass-nav rounded-xl mt-4 p-2 sm:p-3">
            <div class="grid grid-cols-2 gap-2 sm:flex sm:flex-wrap sm:items-center sm:justify-between">
                <a href="#announcement-grid" class="rounded-lg px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-white/70 no-underline transition-colors">
                    <i class="bi bi-megaphone-fill text-blue-700 mr-1"></i>Announcements
                </a>
                <a href="#latest-jobs" class="rounded-lg px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-white/70 no-underline transition-colors">
                    <i class="bi bi-briefcase-fill text-blue-700 mr-1"></i>Latest Job Hiring
                </a>
                <a href="#alumni-spotlight" class="rounded-lg px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-white/70 no-underline transition-colors">
                    <i class="bi bi-stars text-blue-700 mr-1"></i>Alumni Milestone
                </a>
                <span class="rounded-lg px-3 py-2 text-sm font-semibold text-slate-600 bg-white/40 text-center sm:text-left">
                    <i class="bi bi-calendar3 mr-1"></i>{{ 'now'|date('F d, Y') }}
                </span>
            </div>
        </div>
    </section>

    <div class="grid grid-cols-1 xl:grid-cols-12 gap-6">
        <section id="announcement-grid" class="xl:col-span-8 space-y-4" data-controller="announcement-search">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h2 class="text-xl sm:text-2xl font-extrabold text-slate-900 mb-1">Announcement Board</h2>
                    <p class="text-sm text-slate-600">A modern bulletin view inspired by the official NORSU Alumni Affairs identity.</p>
                </div>
                <a href="{{ path('announcement_index') }}" class="blue-action inline-flex items-center justify-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold no-underline transition-all">
                    <i class="bi bi-grid-3x3-gap-fill"></i> View All
                </a>
            </div>

            <div class="relative">
                <label for="announcementSearch" class="sr-only">Search announcements</label>
                <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
                <input
                    id="announcementSearch"
                    type="search"
                    placeholder="Search titles, category, date, or author"
                    class="w-full rounded-xl border border-slate-200 bg-white/90 py-3 pl-10 pr-4 text-sm text-slate-700 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200"
                    data-announcement-search-target="input"
                    data-action="input->announcement-search#onInput focus->announcement-search#onFocus keydown->announcement-search#closeOnEscape"
                    autocomplete="off"
                >
                <div class="absolute left-0 right-0 mt-1 hidden" data-announcement-search-target="suggestions">
                    <div class="rounded-xl border border-slate-200 bg-white shadow-lg overflow-hidden" data-announcement-search-target="suggestionList"></div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 2xl:grid-cols-3 gap-4">
                {% if recentAnnouncements|length > 0 %}
                    {% set visualThemes = [
                        'background: linear-gradient(150deg, #1e3a8a 0%, #2563eb 60%, #38bdf8 100%);',
                        'background: linear-gradient(150deg, #1e40af 0%, #1d4ed8 45%, #f59e0b 100%);',
                        'background: linear-gradient(150deg, #0f172a 0%, #1d4ed8 58%, #facc15 100%);'
                    ] %}
                    {% for a in recentAnnouncements %}
                        {% set authorName = a.postedBy ? (a.postedBy.firstName ~ ' ' ~ a.postedBy.lastName) : 'Office Admin' %}
                        {% set metaText = (a.title ~ ' ' ~ (a.category ?? '') ~ ' ' ~ authorName ~ ' ' ~ a.datePosted|date('F d, Y'))|lower %}
                        <article
                            class="rounded-2xl border border-slate-200 bg-white shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden"
                            data-announcement-search-target="card"
                            data-title="{{ a.title|lower|e('html_attr') }}"
                            data-search-text="{{ metaText|e('html_attr') }}"
                        >
                            <div class="announcement-visual aspect-video {{ loop.index is odd ? 'bg-blue-900' : 'bg-blue-800' }}" style="{{ visualThemes[(loop.index0) % 3] }}">
                                <div class="absolute inset-0 opacity-30" style="background-image: url('{{ asset('images/norsu-logo.webp') }}'); background-size: 120px; background-repeat: no-repeat; background-position: right 1rem top 0.75rem;"></div>
                                <div class="announcement-headline">
                                    <p class="text-[0.65rem] uppercase tracking-[0.22em] text-slate-200 mb-1">NORSU Alumni Affairs</p>
                                    <h3 class="text-white text-lg font-bold leading-tight line-clamp-2">{{ a.title }}</h3>
                                </div>
                            </div>

                            <footer class="bg-white p-4 space-y-3">
                                <p class="text-sm text-slate-600 line-clamp-2">{{ a.description|striptags|slice(0, 130) }}{% if a.description|length > 130 %}...{% endif %}</p>
                                <div class="grid grid-cols-1 gap-1 text-xs text-slate-600">
                                    <span><strong class="text-slate-900">Category:</strong> {{ a.category ?: 'General Notice' }}</span>
                                    <span><strong class="text-slate-900">Date:</strong> {{ a.datePosted|date('M d, Y') }}</span>
                                    <span><strong class="text-slate-900">Author:</strong> {{ authorName }}</span>
                                </div>
                                <div class="flex flex-wrap gap-2 pt-1">
                                    <a href="{{ path('announcement_index') }}" class="blue-action inline-flex items-center gap-1 rounded-lg px-3 py-2 text-xs font-semibold no-underline transition-all">
                                        <i class="bi bi-eye-fill"></i> Read More
                                    </a>
                                    <a href="{{ path('feedback_submit') }}" class="gold-action inline-flex items-center gap-1 rounded-lg px-3 py-2 text-xs font-semibold no-underline transition-all">
                                        <i class="bi bi-chat-left-dots-fill"></i> Send Feedback
                                    </a>
                                </div>
                            </footer>
                        </article>
                    {% endfor %}
                {% endif %}
            </div>

            <div class="hidden rounded-xl border border-dashed border-slate-300 bg-white p-6 text-center text-slate-500" data-announcement-search-target="emptyState">
                <i class="bi bi-search text-2xl block mb-2"></i>
                No matching announcements found.
            </div>

            {% if recentAnnouncements|length == 0 %}
                <div class="rounded-xl border border-dashed border-slate-300 bg-white p-8 text-center text-slate-500">
                    <i class="bi bi-megaphone text-3xl block mb-2"></i>
                    No active announcements available right now.
                </div>
            {% endif %}
        </section>

        <aside class="xl:col-span-4 space-y-4">
            <section id="latest-jobs" class="rounded-2xl border border-slate-200 bg-white shadow-sm p-4">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-extrabold text-slate-900 mb-0">
                        <i class="bi bi-briefcase-fill text-blue-700 mr-1"></i> Latest Job Hiring
                    </h3>
                    <a href="{{ path('job_board_index') }}" class="text-xs font-semibold text-blue-700 no-underline hover:underline">View board</a>
                </div>

                {% if recentJobs|length > 0 %}
                    <div class="job-ticker-window rounded-xl bg-slate-50 p-2">
                        <div class="job-ticker-track flex flex-col gap-2">
                            {% for j in recentJobs %}
                                <a href="{{ path('job_board_show', {id: j.id}) }}" class="block rounded-lg bg-white border border-slate-200 p-3 no-underline hover:border-blue-400 transition-colors">
                                    <p class="text-xs uppercase tracking-wide text-blue-700 font-semibold mb-1">{{ j.employmentType ?: 'Open Position' }}</p>
                                    <h4 class="text-sm font-bold text-slate-900 leading-snug mb-1 line-clamp-2">{{ j.title }}</h4>
                                    <p class="text-xs text-slate-600 mb-0">{{ j.companyName }}{% if j.location %} • {{ j.location }}{% endif %}</p>
                                </a>
                            {% endfor %}
                            {% for j in recentJobs|slice(0, 4) %}
                                <a href="{{ path('job_board_show', {id: j.id}) }}" class="block rounded-lg bg-white border border-slate-200 p-3 no-underline hover:border-blue-400 transition-colors" aria-hidden="true" tabindex="-1">
                                    <p class="text-xs uppercase tracking-wide text-blue-700 font-semibold mb-1">{{ j.employmentType ?: 'Open Position' }}</p>
                                    <h4 class="text-sm font-bold text-slate-900 leading-snug mb-1 line-clamp-2">{{ j.title }}</h4>
                                    <p class="text-xs text-slate-600 mb-0">{{ j.companyName }}{% if j.location %} • {{ j.location }}{% endif %}</p>
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                {% else %}
                    <div class="rounded-xl border border-dashed border-slate-300 p-4 text-center text-slate-500 text-sm">
                        Job listings will appear here when new postings are published.
                    </div>
                {% endif %}
            </section>

            <section class="rounded-2xl border border-amber-300/70 bg-amber-50/60 shadow-sm p-4">
                <h3 class="text-base font-extrabold text-slate-900 mb-2">
                    <i class="bi bi-patch-check-fill text-amber-600 mr-1"></i> Graduate Tracer Survey
                </h3>
                {% if hasGtsSurvey %}
                    <p class="text-sm text-emerald-700 font-semibold mb-0">Completed. Thank you for participating.</p>
                {% else %}
                    <p class="text-sm text-slate-700 mb-3">Share your post-graduation journey to help improve university programs.</p>
                    <a href="{{ path('gts_new') }}" class="blue-action inline-flex items-center gap-2 rounded-lg px-3 py-2 text-xs font-semibold no-underline transition-all">
                        <i class="bi bi-pencil-square"></i> Start Survey
                    </a>
                {% endif %}
            </section>
        </aside>
    </div>

    <section id="alumni-spotlight" class="space-y-3">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-2">
            <div>
                <h2 class="text-xl sm:text-2xl font-extrabold text-slate-900 mb-1">Alumni Milestone Spotlight</h2>
                <p class="text-sm text-slate-600">Celebrating board topnotchers and alumni with notable career breakthroughs.</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
            {% if milestoneAlumni|length > 0 %}
                {% for m in milestoneAlumni %}
                    <article class="spotlight-card rounded-2xl p-4 relative overflow-hidden">
                        <span class="spotlight-ribbon inline-flex items-center gap-1 text-[0.68rem] font-bold uppercase tracking-[0.15em] rounded-full px-2.5 py-1 mb-3">
                            <i class="bi bi-stars"></i> Spotlight
                        </span>
                        <h3 class="text-base font-extrabold text-slate-900 mb-1">{{ m.fullName }}</h3>
                        <p class="text-xs text-slate-600 mb-2">{{ m.course ?: 'NORSU Graduate' }}{% if m.yearGraduated %} • Batch {{ m.yearGraduated }}{% endif %}</p>
                        <p class="text-sm text-slate-700 mb-0 line-clamp-4">
                            {{ m.honorsReceived ?: (m.careerAchievements ?: (m.jobTitle ?: 'Excelling in professional practice and community leadership.')) }}
                        </p>
                    </article>
                {% endfor %}
            {% else %}
                <div class="md:col-span-2 xl:col-span-4 rounded-xl border border-dashed border-amber-300 bg-amber-50/50 p-6 text-center text-slate-600">
                    Milestone stories will appear here once alumni achievements are added to the database.
                </div>
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}
