{% extends 'base.html.twig' %}

{% block title %}FAQ — NORSU Alumni Tracker{% endblock %}

{% block body %}
<div class="hero-section relative overflow-hidden text-white py-16 mb-8" style="background-color:#1E3A8A;background-image:linear-gradient(118deg,rgba(6,24,63,0.84) 0%,rgba(13,65,120,0.66) 48%,rgba(5,150,105,0.54) 100%),url('{{ asset('images/home-hero-graduation.png') }}');background-size:cover;background-position:center;background-repeat:no-repeat;">
    <div class="max-w-5xl mx-auto px-4 relative z-10 text-center" style="padding-top:2rem;">
        <h1 class="font-extrabold text-4xl md:text-5xl mb-3">Frequently Asked Questions</h1>
        <p class="text-lg text-white/90 max-w-3xl mx-auto">Answers to common questions about registration, profile management, tracer surveys, and account access.</p>
    </div>
</div>

<div class="max-w-4xl mx-auto px-4 pb-8 space-y-3">
    <div class="card">
        <div class="card-body">
            <h6 class="font-bold text-blue-800 mb-1">How do I create an alumni account?</h6>
            <p class="text-sm text-gray-600 mb-0">Go to Register, complete your details, and wait for account verification by the assigned staff.</p>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h6 class="font-bold text-blue-800 mb-1">Why is my account still pending?</h6>
            <p class="text-sm text-gray-600 mb-0">Pending status means your details are still under review. Staff verifies submissions before activation.</p>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h6 class="font-bold text-blue-800 mb-1">Can I edit my personal information later?</h6>
            <p class="text-sm text-gray-600 mb-0">Yes. Open My Profile and select Edit Profile to update your information and profile picture.</p>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h6 class="font-bold text-blue-800 mb-1">What is the Graduate Tracer Survey for?</h6>
            <p class="text-sm text-gray-600 mb-0">It helps the university assess employment outcomes, skills relevance, and program impact after graduation.</p>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h6 class="font-bold text-blue-800 mb-1">How can I recover my password?</h6>
            <p class="text-sm text-gray-600 mb-0">Use the Forgot Password link on the login page and follow the reset instructions sent to your email.</p>
        </div>
    </div>
</div>

{% include 'home/_public_footer.html.twig' %}
{% endblock %}
