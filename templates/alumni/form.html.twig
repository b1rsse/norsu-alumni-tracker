{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1>{{ title }}</h1>

    {{ form_start(form) }}
        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    {{ form_label(form.studentId) }}
                    {{ form_widget(form.studentId, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.studentId) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.firstName) }}
                    {{ form_widget(form.firstName, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.firstName) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.lastName) }}
                    {{ form_widget(form.lastName, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.lastName) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.email) }}
                    {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.email) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.phone) }}
                    {{ form_widget(form.phone, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.phone) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.course) }}
                    {{ form_widget(form.course, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.course) }}
                </div>
            </div>

            <div class="col-md-6">
                <div class="mb-3">
                    {{ form_label(form.batchYear) }}
                    {{ form_widget(form.batchYear, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.batchYear) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.currentEmploymentStatus) }}
                    {{ form_widget(form.currentEmploymentStatus, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.currentEmploymentStatus) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.current_position) }}
                    {{ form_widget(form.current_position, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.current_position) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.company_name) }}
                    {{ form_widget(form.company_name, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.company_name) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.salary_range) }}
                    {{ form_widget(form.salary_range, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.salary_range) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.location) }}
                    {{ form_widget(form.location, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.location) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.skills) }}
                    {{ form_widget(form.skills, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.skills) }}
                </div>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Save</button>
            <a href="{{ path('alumni_index') }}" class="btn btn-secondary">Cancel</a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
