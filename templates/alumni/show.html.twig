{% extends 'base.html.twig' %}

{% block title %}{{ alumni.fullName }}{% endblock %}

{% block body %}
{# ── Header ── #}
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
    <div>
        <h4 class="fw-bold mb-1">{{ alumni.fullName }}</h4>
        <span class="text-muted">{{ alumni.studentNumber }} &middot; {{ alumni.course }} {{ alumni.yearGraduated ? '(' ~ alumni.yearGraduated ~ ')' : '' }}</span>
    </div>
    <div class="mt-2 mt-md-0 d-flex gap-2">
        <a href="{{ path('alumni_edit', {id: alumni.id}) }}" class="btn btn-norsu"><i class="bi bi-pencil me-1"></i>Edit</a>
        <a href="{{ path('alumni_index') }}" class="btn btn-outline-norsu"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>

<div class="row g-4">
    {# ── LEFT COLUMN ── #}
    <div class="col-lg-4">
        {# Profile Card #}
        <div class="card mb-4">
            <div class="card-body text-center">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                     style="width:80px;height:80px;background:#D1FAE5;font-size:2rem;color:#059669;font-weight:700;">
                    {{ alumni.firstName|first }}{{ alumni.lastName|first }}
                </div>
                <h5 class="fw-bold mb-1">{{ alumni.fullName }}</h5>
                <p class="text-muted small mb-2">{{ alumni.emailAddress }}</p>
                {% if alumni.employmentStatus %}
                    {% if alumni.employmentStatus == 'Employed' %}
                        <span class="badge badge-employed">{{ alumni.employmentStatus }}</span>
                    {% elseif alumni.employmentStatus == 'Self-Employed' %}
                        <span class="badge badge-self-employed">{{ alumni.employmentStatus }}</span>
                    {% elseif alumni.employmentStatus == 'Unemployed' %}
                        <span class="badge badge-unemployed">{{ alumni.employmentStatus }}</span>
                    {% else %}
                        <span class="badge bg-secondary">{{ alumni.employmentStatus }}</span>
                    {% endif %}
                {% endif %}
            </div>
            <ul class="list-group list-group-flush small">
                <li class="list-group-item d-flex justify-content-between"><span class="text-muted">Sex</span><span>{{ alumni.sex ?? '—' }}</span></li>
                <li class="list-group-item d-flex justify-content-between"><span class="text-muted">Date of Birth</span><span>{{ alumni.dateOfBirth ? alumni.dateOfBirth|date('M d, Y') : '—' }}</span></li>
                <li class="list-group-item d-flex justify-content-between"><span class="text-muted">Civil Status</span><span>{{ alumni.civilStatus ?? '—' }}</span></li>
                <li class="list-group-item d-flex justify-content-between"><span class="text-muted">Contact</span><span>{{ alumni.contactNumber ?? '—' }}</span></li>
                <li class="list-group-item d-flex justify-content-between"><span class="text-muted">Province</span><span>{{ alumni.province ?? '—' }}</span></li>
            </ul>
        </div>

        {# Address #}
        {% if alumni.homeAddress %}
        <div class="card mb-4">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-geo-alt me-1"></i> Address</div>
            <div class="card-body small">{{ alumni.homeAddress }}</div>
        </div>
        {% endif %}

        {# University Contribution #}
        <div class="card mb-4">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-heart me-1"></i> Willingness</div>
            <div class="card-body small">
                <div class="d-flex align-items-center mb-2">
                    <i class="bi {{ alumni.recommendNorsu ? 'bi-check-circle-fill text-success' : 'bi-dash-circle text-muted' }} me-2"></i>
                    Recommend NORSU
                </div>
                <div class="d-flex align-items-center mb-2">
                    <i class="bi {{ alumni.willingForSeminar ? 'bi-check-circle-fill text-success' : 'bi-dash-circle text-muted' }} me-2"></i>
                    Guest Speaker / Seminar
                </div>
                <div class="d-flex align-items-center mb-2">
                    <i class="bi {{ alumni.willingForDonation ? 'bi-check-circle-fill text-success' : 'bi-dash-circle text-muted' }} me-2"></i>
                    Donation
                </div>
                <div class="d-flex align-items-center">
                    <i class="bi {{ alumni.willingForMentorship ? 'bi-check-circle-fill text-success' : 'bi-dash-circle text-muted' }} me-2"></i>
                    Mentorship
                </div>
            </div>
        </div>
    </div>

    {# ── RIGHT COLUMN ── #}
    <div class="col-lg-8">
        {# Academic #}
        <div class="card mb-4">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-mortarboard me-1"></i> Academic Information</div>
            <div class="card-body">
                <div class="row g-3 small">
                    <div class="col-sm-6"><span class="text-muted d-block">Course</span><strong>{{ alumni.course }}</strong></div>
                    <div class="col-sm-6"><span class="text-muted d-block">College</span><strong>{{ alumni.college ?? '—' }}</strong></div>
                    <div class="col-sm-6"><span class="text-muted d-block">Degree Program</span><strong>{{ alumni.degreeProgram ?? '—' }}</strong></div>
                    <div class="col-sm-6"><span class="text-muted d-block">Major</span><strong>{{ alumni.major ?? '—' }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">Year Graduated</span><strong>{{ alumni.yearGraduated ?? '—' }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">Date Graduated</span><strong>{{ alumni.dateGraduated ? alumni.dateGraduated|date('M d, Y') : '—' }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">GWA</span><strong>{{ alumni.gwa ?? '—' }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">Latin Honor</span><strong>{{ alumni.latinHonor ?? '—' }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">Honors Received</span><strong>{{ alumni.honorsReceived ?? '—' }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">Scholarship</span><strong>{{ alumni.scholarshipGranted ?? '—' }}</strong></div>
                </div>
            </div>
        </div>

        {# Employment #}
        <div class="card mb-4">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-briefcase me-1"></i> Employment Information</div>
            <div class="card-body">
                <div class="row g-3 small">
                    <div class="col-sm-4"><span class="text-muted d-block">Employment Status</span><strong>{{ alumni.employmentStatus ?? '—' }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">Employment Type</span><strong>{{ alumni.employmentType ?? '—' }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">Job Level</span><strong>{{ alumni.jobLevel ?? '—' }}</strong></div>
                    <div class="col-sm-6"><span class="text-muted d-block">Company</span><strong>{{ alumni.companyName ?? '—' }}</strong></div>
                    <div class="col-sm-6"><span class="text-muted d-block">Job Title</span><strong>{{ alumni.jobTitle ?? '—' }}</strong></div>
                    <div class="col-sm-6"><span class="text-muted d-block">Industry</span><strong>{{ alumni.industry ?? '—' }}</strong></div>
                    <div class="col-sm-6"><span class="text-muted d-block">Company Address</span><strong>{{ alumni.companyAddress ?? '—' }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">Date Hired</span><strong>{{ alumni.dateHired ? alumni.dateHired|date('M d, Y') : '—' }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">Monthly Salary</span><strong>{{ alumni.monthlySalary ?? '—' }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">Years in Company</span><strong>{{ alumni.yearsInCompany ?? '—' }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">First Job?</span><strong>{{ alumni.isFirstJob is null ? '—' : (alumni.isFirstJob ? 'Yes' : 'No') }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">Works Abroad?</span><strong>{{ alumni.workAbroad is null ? '—' : (alumni.workAbroad ? 'Yes' : 'No') }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">Country</span><strong>{{ alumni.countryOfEmployment ?? '—' }}</strong></div>
                </div>
            </div>
        </div>

        {# Career Tracking #}
        <div class="card mb-4">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-graph-up-arrow me-1"></i> Career Tracking</div>
            <div class="card-body">
                <div class="row g-3 small">
                    <div class="col-sm-4"><span class="text-muted d-block">Job Related to Course?</span><strong>{{ alumni.jobRelatedToCourse is null ? '—' : (alumni.jobRelatedToCourse ? 'Yes' : 'No') }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">Promotion Received?</span><strong>{{ alumni.promotionReceived is null ? '—' : (alumni.promotionReceived ? 'Yes' : 'No') }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">Date Promoted</span><strong>{{ alumni.datePromoted ? alumni.datePromoted|date('M d, Y') : '—' }}</strong></div>
                    <div class="col-sm-6"><span class="text-muted d-block">Skills Used</span><strong>{{ alumni.skillsUsedInJob ?? '—' }}</strong></div>
                    <div class="col-sm-6"><span class="text-muted d-block">Trainings Attended</span><strong>{{ alumni.trainingsAttended ?? '—' }}</strong></div>
                    <div class="col-sm-6"><span class="text-muted d-block">Licenses Obtained</span><strong>{{ alumni.licensesObtained ?? '—' }}</strong></div>
                    <div class="col-sm-6"><span class="text-muted d-block">Certifications</span><strong>{{ alumni.certifications ?? '—' }}</strong></div>
                    <div class="col-12"><span class="text-muted d-block">Career Achievements</span><strong>{{ alumni.careerAchievements ?? '—' }}</strong></div>
                </div>
            </div>
        </div>

        {# Further Studies & Feedback #}
        <div class="card mb-4">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-book me-1"></i> Further Studies & Feedback</div>
            <div class="card-body">
                <div class="row g-3 small">
                    <div class="col-sm-4"><span class="text-muted d-block">Pursuing Further Studies?</span><strong>{{ alumni.furtherStudies is null ? '—' : (alumni.furtherStudies ? 'Yes' : 'No') }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">Postgraduate Degree</span><strong>{{ alumni.postgraduateDegree ?? '—' }}</strong></div>
                    <div class="col-sm-4"><span class="text-muted d-block">School</span><strong>{{ alumni.schoolForFurtherStudies ?? '—' }}</strong></div>
                    <div class="col-12"><span class="text-muted d-block">Suggestions for University</span><strong>{{ alumni.suggestionsForUniversity ?? '—' }}</strong></div>
                </div>
            </div>
        </div>

        {# Employment History (from related Employment entity) #}
        <div class="card mb-4">
            <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-clock-history me-1"></i> Employment History</span>
            </div>
            <div class="card-body">
                {% if alumni.employments|length > 0 %}
                    {% for emp in alumni.employments %}
                    <div class="{% if not loop.last %}mb-3 pb-3 border-bottom{% endif %}">
                        <div class="d-flex justify-content-between">
                            <div>
                                <strong>{{ emp.jobTitle ?? 'Position N/A' }}</strong>
                                <span class="text-muted">at {{ emp.companyName ?? 'Company N/A' }}</span>
                            </div>
                            <span class="badge bg-light text-dark small">{{ emp.employmentStatus ?? '' }}</span>
                        </div>
                        <div class="small text-muted mt-1">
                            {{ emp.dateHired ? emp.dateHired|date('M Y') : '?' }} — {{ emp.dateEnded ? emp.dateEnded|date('M Y') : 'Present' }}
                            {% if emp.industry %} &middot; {{ emp.industry }}{% endif %}
                            {% if emp.isAbroad %} &middot; <i class="bi bi-globe2"></i> {{ emp.country ?? 'Abroad' }}{% endif %}
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <p class="text-muted mb-0 small">No employment history records.</p>
                {% endif %}
            </div>
        </div>

        {# Documents #}
        <div class="card mb-4">
            <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-file-earmark me-1"></i> Documents</span>
                <a href="{{ path('document_upload', {alumniId: alumni.id}) }}" class="btn btn-sm btn-norsu-gold"><i class="bi bi-upload me-1"></i>Upload</a>
            </div>
            <div class="card-body">
                {% if alumni.documents|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light"><tr><th>Type</th><th>Filename</th><th>Uploaded</th></tr></thead>
                            <tbody>
                            {% for doc in alumni.documents %}
                                <tr>
                                    <td><span class="badge bg-light text-dark">{{ doc.documentType }}</span></td>
                                    <td>{{ doc.originalFilename }}</td>
                                    <td>{{ doc.uploadedAt|date('M d, Y') }}</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <p class="text-muted mb-0 small">No documents uploaded.</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
