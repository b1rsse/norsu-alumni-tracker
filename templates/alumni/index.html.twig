{% extends 'base.html.twig' %}

{% block title %}Alumni Directory{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0"><i class="bi bi-people-fill me-2"></i>Alumni Directory</h4>
    <a href="{{ path('alumni_create') }}" class="btn btn-norsu"><i class="bi bi-person-plus-fill me-1"></i> Add Alumni</a>
</div>

{# ── Search & Filters ── #}
<div class="card mb-4">
    <div class="card-body">
        <form method="get" action="{{ path('alumni_index') }}">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Search</label>
                    <input type="text" name="q" value="{{ search }}" class="form-control" placeholder="Name, Student No, Email...">
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Course</label>
                    <select name="course" class="form-select">
                        <option value="">All Courses</option>
                        {% for c in courses %}<option value="{{ c }}" {{ filter_course == c ? 'selected' }}>{{ c }}</option>{% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Year</label>
                    <select name="year" class="form-select">
                        <option value="">All Years</option>
                        {% for y in years %}<option value="{{ y }}" {{ filter_year == y ? 'selected' }}>{{ y }}</option>{% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Status</label>
                    <select name="status" class="form-select">
                        <option value="">All Status</option>
                        <option value="Employed" {{ filter_status == 'Employed' ? 'selected' }}>Employed</option>
                        <option value="Self-Employed" {{ filter_status == 'Self-Employed' ? 'selected' }}>Self-Employed</option>
                        <option value="Unemployed" {{ filter_status == 'Unemployed' ? 'selected' }}>Unemployed</option>
                        <option value="Freelance" {{ filter_status == 'Freelance' ? 'selected' }}>Freelance</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button class="btn btn-norsu flex-fill"><i class="bi bi-search me-1"></i>Filter</button>
                    <a href="{{ path('alumni_index') }}" class="btn btn-outline-secondary flex-fill">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

{# ── Results Count ── #}
<p class="text-muted small mb-2"><strong>{{ alumnis|length }}</strong> alumni found</p>

{# ── Table ── #}
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Student No.</th>
                        <th>Name</th>
                        <th>Course</th>
                        <th>Year</th>
                        <th>Province</th>
                        <th>Status</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for alumni in alumnis %}
                    <tr>
                        <td class="ps-3"><span class="badge bg-light text-dark">{{ alumni.studentNumber }}</span></td>
                        <td>
                            <div class="fw-semibold">{{ alumni.lastName }}, {{ alumni.firstName }}{% if alumni.suffix %} {{ alumni.suffix }}{% endif %}</div>
                            <small class="text-muted">{{ alumni.emailAddress }}</small>
                        </td>
                        <td>{{ alumni.course }}</td>
                        <td>{{ alumni.yearGraduated ?? '—' }}</td>
                        <td>{{ alumni.province ?? '—' }}</td>
                        <td>
                            {% if alumni.employmentStatus == 'Employed' %}
                                <span class="badge badge-employed">Employed</span>
                            {% elseif alumni.employmentStatus == 'Self-Employed' %}
                                <span class="badge badge-self-employed">Self-Employed</span>
                            {% elseif alumni.employmentStatus == 'Unemployed' %}
                                <span class="badge badge-unemployed">Unemployed</span>
                            {% elseif alumni.employmentStatus == 'Freelance' %}
                                <span class="badge badge-freelance">Freelance</span>
                            {% else %}
                                <span class="badge bg-secondary">{{ alumni.employmentStatus ?? 'N/A' }}</span>
                            {% endif %}
                        </td>
                        <td class="text-end pe-3">
                            <a href="{{ path('alumni_show', {id: alumni.id}) }}" class="btn btn-sm btn-outline-norsu" title="View"><i class="bi bi-eye"></i></a>
                            <a href="{{ path('alumni_edit', {id: alumni.id}) }}" class="btn btn-sm btn-outline-warning" title="Edit"><i class="bi bi-pencil"></i></a>
                            {% if is_granted('ROLE_ADMIN') %}
                            <form method="post" action="{{ path('alumni_delete', {id: alumni.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Delete this alumni record?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ alumni.id) }}">
                                <button class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                            </form>
                            {% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-1 d-block mb-2 opacity-25"></i>
                            No alumni records found.
                            <a href="{{ path('alumni_create') }}">Add the first one</a>.
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
