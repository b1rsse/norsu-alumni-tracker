{% extends 'base.html.twig' %}

{% block title %}Alumni Directory{% endblock %}

{% block body %}
<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">NORSU Graduates</h1>
    <div>
      <a href="{{ path('alumni_create') }}" class="btn btn-success btn-sm">+ Add Alumni</a>
      <a href="{{ path('alumni_index') }}" class="btn btn-outline-secondary btn-sm ms-2">Refresh</a>
    </div>
  </div>

  <form class="row g-2 mb-4" method="get" action="{{ path('alumni_index') }}">
    <div class="col-sm-4">
      <input type="text" name="course" value="{{ search_course|default('') }}" class="form-control" placeholder="Course (e.g., BSIT)">
    </div>
    <div class="col-sm-3">
      <input type="number" name="batch" value="{{ search_batch|default('') }}" class="form-control" placeholder="Batch Year">
    </div>
    <div class="col-auto">
      <button class="btn btn-primary">Search</button>
      <a href="{{ path('alumni_index') }}" class="btn btn-outline-secondary ms-2">Reset</a>
    </div>
  </form>

  <div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th>Student ID</th>
          <th>Name</th>
          <th>Course</th>
          <th>Batch Year</th>
          <th>Employment Status</th>
          <th>Email</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for alumni in alumnis %}
          <tr>
            <td>{{ alumni.studentId }}</td>
            <td>{{ alumni.lastName }}, {{ alumni.firstName }}</td>
            <td>{{ alumni.course }}</td>
            <td>{{ alumni.batchYear }}</td>
            <td>{{ alumni.currentEmploymentStatus ?: 'N/A' }}</td>
            <td><a href="mailto:{{ alumni.email }}">{{ alumni.email }}</a></td>
            <td class="text-end">
              <a href="{{ path('alumni_show', {'id': alumni.id}) }}" class="btn btn-sm btn-outline-primary">View</a>
              <a href="{{ path('alumni_edit', {'id': alumni.id}) }}" class="btn btn-sm btn-outline-warning">Edit</a>
              <a href="{{ path('alumni_edit', {'id': alumni.id}) }}" class="btn btn-sm btn-outline-secondary">Edit</a>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="7" class="text-center">No records found.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}
