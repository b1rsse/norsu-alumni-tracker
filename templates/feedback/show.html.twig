{% extends 'base.html.twig' %}

{% block title %}Feedback Detail{% endblock %}

{% block body %}
<div class="flex justify-between items-center mb-3">
    <h4 class="font-bold mb-0">Feedback Detail</h4>
    <a href="{{ path('feedback_index') }}" class="btn-outline-norsu"><i class="bi bi-arrow-left mr-1"></i>Back</a>
</div>

<div class="card">
    <div class="card-body">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
            <div>
                <span class="text-gray-500 block">From</span>
                <strong>{{ feedback.alumni ? feedback.alumni.fullName : 'Anonymous' }}</strong>
            </div>
            <div>
                <span class="text-gray-500 block">Date Submitted</span>
                <strong>{{ feedback.dateSubmitted|date('F d, Y \\a\\t h:i A') }}</strong>
            </div>
            <div>
                <span class="text-gray-500 block">Recommend NORSU?</span>
                {% if feedback.recommendUniversity %}
                    <span class="badge badge-employed">Yes</span>
                {% else %}
                    <span class="badge badge-secondary">No</span>
                {% endif %}
            </div>
            <div class="sm:col-span-2">
                <span class="text-gray-500 block">Suggestions</span>
                <div class="mt-1 p-3 bg-gray-100 rounded-lg">{{ feedback.suggestions ?? 'No suggestions provided.' }}</div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
