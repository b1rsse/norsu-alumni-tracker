{% extends 'base.html.twig' %}

{% block title %}Feedback Detail{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">Feedback Detail</h4>
    <a href="{{ path('feedback_index') }}" class="btn btn-outline-norsu"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="card">
    <div class="card-body">
        <div class="row g-3 small">
            <div class="col-sm-6">
                <span class="text-muted d-block">From</span>
                <strong>{{ feedback.alumni ? feedback.alumni.fullName : 'Anonymous' }}</strong>
            </div>
            <div class="col-sm-6">
                <span class="text-muted d-block">Date Submitted</span>
                <strong>{{ feedback.dateSubmitted|date('F d, Y \\a\\t h:i A') }}</strong>
            </div>
            <div class="col-sm-6">
                <span class="text-muted d-block">Recommend NORSU?</span>
                {% if feedback.recommendUniversity %}
                    <span class="badge badge-employed">Yes</span>
                {% else %}
                    <span class="badge bg-secondary">No</span>
                {% endif %}
            </div>
            <div class="col-12">
                <span class="text-muted d-block">Suggestions</span>
                <div class="mt-1 p-3 bg-light rounded">{{ feedback.suggestions ?? 'No suggestions provided.' }}</div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
