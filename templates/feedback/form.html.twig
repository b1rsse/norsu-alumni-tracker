{% extends 'base.html.twig' %}

{% block title %}Submit Feedback{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0"><i class="bi bi-chat-dots me-2"></i>Submit Feedback</h4>
    <a href="{{ path('app_home') }}" class="btn btn-outline-norsu"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="card">
    <div class="card-body">
        <p class="text-muted mb-4">We value your opinion. Please share your suggestions and feedback about NORSU and our programs.</p>

        {{ form_start(form) }}
            <div class="row g-3">
                <div class="col-12">{{ form_row(form.suggestions) }}</div>
                <div class="col-12"><div class="form-check">{{ form_row(form.recommendUniversity) }}</div></div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-norsu"><i class="bi bi-send me-1"></i>Submit Feedback</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
