{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard - NORSU Alumni Tracker{% endblock %}

{% block body %}
<style>
    .admin-dashboard {
        --dash-primary: #1e3a8a;
        --dash-primary-strong: #1d4ed8;
        --dash-accent: #059669;
        --dash-bg: #f4f7fb;
        --dash-card: #ffffff;
        --dash-border: #e3ebf6;
        --dash-text: #0f172a;
        --dash-muted: #64748b;
        font-family: "Sora", "Manrope", sans-serif;
        font-size: 0.95rem;
        line-height: 1.45;
        color: var(--dash-text);
    }

    .admin-dashboard .dashboard-shell {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .admin-dashboard .card-enter {
        animation: dashboard-enter 0.35s ease-out both;
    }

    .admin-dashboard .hero-panel {
        position: relative;
        overflow: hidden;
        border-radius: 1rem;
        background:
            radial-gradient(circle at 86% 14%, rgba(255, 255, 255, 0.18), transparent 36%),
            linear-gradient(118deg, #102a69 0%, #1e40af 52%, #0f766e 100%);
        color: #fff;
        box-shadow: 0 16px 36px rgba(16, 42, 105, 0.28);
    }

    .admin-dashboard .hero-panel::before {
        content: "";
        position: absolute;
        right: -42px;
        bottom: -70px;
        width: 180px;
        height: 180px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
    }

    .admin-dashboard .hero-main {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1.15rem 1.2rem 0.95rem;
    }

    .admin-dashboard .hero-user {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        min-width: 0;
    }

    .admin-dashboard .hero-avatar {
        width: 52px;
        height: 52px;
        border-radius: 999px;
        border: 2px solid rgba(255, 255, 255, 0.36);
        background: rgba(255, 255, 255, 0.17);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        flex-shrink: 0;
        backdrop-filter: blur(4px);
    }

    .admin-dashboard .hero-title {
        margin: 0;
        font-size: 1.72rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .admin-dashboard .hero-subtitle {
        margin: 0.28rem 0 0;
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.86);
    }

    .admin-dashboard .hero-actions {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .admin-dashboard .hero-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border-radius: 0.55rem;
        padding: 0.5rem 0.78rem;
        font-size: 0.8rem;
        font-weight: 700;
        text-decoration: none;
        transition: transform 0.16s ease, box-shadow 0.16s ease, background-color 0.16s ease;
    }

    .admin-dashboard .hero-btn:hover {
        transform: translateY(-1px);
    }

    .admin-dashboard .hero-btn-soft {
        color: #1f2937;
        background: #ffffff;
        box-shadow: 0 2px 12px rgba(15, 23, 42, 0.12);
    }

    .admin-dashboard .hero-btn-soft:hover {
        background: #f8fafc;
    }

    .admin-dashboard .hero-btn-solid {
        color: #fff;
        background: #059669;
        box-shadow: 0 2px 12px rgba(5, 150, 105, 0.38);
    }

    .admin-dashboard .hero-btn-solid:hover {
        background: #047857;
    }

    .admin-dashboard .hero-meta {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem 1.25rem;
        padding: 0.62rem 1.2rem 0.74rem;
        border-top: 1px solid rgba(255, 255, 255, 0.16);
        background: rgba(0, 0, 0, 0.13);
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.86);
    }

    .admin-dashboard .hero-meta i {
        margin-right: 0.22rem;
    }

    .admin-dashboard .hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.16rem 0.54rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.25);
        background: rgba(255, 255, 255, 0.18);
        font-size: 0.74rem;
        font-weight: 700;
        color: #fff;
    }

    .admin-dashboard .metric-grid {
        display: grid;
        gap: 0.75rem;
        grid-template-columns: repeat(1, minmax(0, 1fr));
    }

    .admin-dashboard .metric-card {
        border: 1px solid var(--dash-border);
        border-radius: 0.95rem;
        background: var(--dash-card);
        padding: 0.88rem 0.95rem;
        box-shadow: 0 7px 18px rgba(15, 23, 42, 0.04);
        transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
    }

    .admin-dashboard .metric-card:hover {
        transform: translateY(-2px);
        border-color: #d2ddf1;
        box-shadow: 0 12px 26px rgba(30, 64, 175, 0.1);
    }

    .admin-dashboard .metric-top {
        display: flex;
        align-items: center;
        gap: 0.56rem;
        margin-bottom: 0.54rem;
    }

    .admin-dashboard .metric-icon {
        width: 38px;
        height: 38px;
        border-radius: 0.72rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.98rem;
    }

    .admin-dashboard .metric-icon.primary {
        background: #e0ecff;
        color: #1d4ed8;
    }

    .admin-dashboard .metric-icon.accent {
        background: #d7f4ea;
        color: #047857;
    }

    .admin-dashboard .metric-icon.warning {
        background: #fef3c7;
        color: #b45309;
    }

    .admin-dashboard .metric-icon.neutral {
        background: #e2e8f0;
        color: #334155;
    }

    .admin-dashboard .metric-label {
        font-size: 0.81rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #475569;
    }

    .admin-dashboard .metric-value {
        font-size: 1.55rem;
        font-weight: 800;
        line-height: 1;
        letter-spacing: -0.01em;
        color: #0f172a;
        margin-bottom: 0.18rem;
    }

    .admin-dashboard .metric-value.metric-warning {
        color: #b45309;
    }

    .admin-dashboard .metric-value.metric-success {
        color: #047857;
    }

    .admin-dashboard .metric-note {
        margin: 0;
        font-size: 0.8rem;
        color: var(--dash-muted);
    }

    .admin-dashboard .kpi-band {
        border: 1px solid var(--dash-border);
        border-radius: 0.95rem;
        background: linear-gradient(120deg, #f8fbff 0%, #ffffff 56%, #f3fbf8 100%);
        display: grid;
        grid-template-columns: repeat(1, minmax(0, 1fr));
        overflow: hidden;
    }

    .admin-dashboard .kpi-item {
        padding: 0.8rem 0.95rem;
        border-bottom: 1px dashed #d5e1f4;
    }

    .admin-dashboard .kpi-item:last-child {
        border-bottom: 0;
    }

    .admin-dashboard .kpi-label {
        margin: 0;
        font-size: 0.74rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #475569;
    }

    .admin-dashboard .kpi-main {
        margin-top: 0.28rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.6rem;
    }

    .admin-dashboard .kpi-value {
        font-size: 1.45rem;
        font-weight: 800;
        line-height: 1;
    }

    .admin-dashboard .kpi-value.primary {
        color: #1d4ed8;
    }

    .admin-dashboard .kpi-value.success {
        color: #047857;
    }

    .admin-dashboard .kpi-value.warning {
        color: #b45309;
    }

    .admin-dashboard .kpi-value.neutral {
        color: #0f766e;
    }

    .admin-dashboard .kpi-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.16rem 0.52rem;
        font-size: 0.73rem;
        font-weight: 700;
    }

    .admin-dashboard .kpi-badge.primary {
        background: #dbeafe;
        color: #1e40af;
    }

    .admin-dashboard .kpi-badge.success {
        background: #dcfce7;
        color: #166534;
    }

    .admin-dashboard .kpi-badge.warning {
        background: #fef3c7;
        color: #92400e;
    }

    .admin-dashboard .panel-card {
        border: 1px solid var(--dash-border);
        border-radius: 0.95rem;
        background: var(--dash-card);
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
        overflow: hidden;
    }

    .admin-dashboard .panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 1rem 1.1rem 0.82rem;
        border-bottom: 1px solid #edf2fa;
    }

    .admin-dashboard .panel-title {
        margin: 0;
        display: inline-flex;
        align-items: center;
        gap: 0.42rem;
        font-size: 1rem;
        font-weight: 700;
        color: #1e3a8a;
    }

    .admin-dashboard .panel-subtitle {
        font-size: 0.78rem;
        color: #64748b;
        white-space: nowrap;
    }

    .admin-dashboard .panel-body {
        padding: 1.05rem 1.1rem;
    }

    .admin-dashboard .panel-body-tight {
        padding: 0;
    }

    .admin-dashboard .employment-ring {
        position: relative;
        width: 132px;
        height: 132px;
        margin: 0 auto;
    }

    .admin-dashboard .employment-score {
        position: absolute;
        inset: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 800;
        color: #1d4ed8;
    }

    .admin-dashboard .employment-caption {
        margin: 0.75rem 0 0.92rem;
        text-align: center;
        font-size: 0.85rem;
        color: #64748b;
    }

    .admin-dashboard .employment-breakdown {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.5rem;
        text-align: center;
    }

    .admin-dashboard .employment-number {
        font-size: 1.02rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .admin-dashboard .employment-number.employed {
        color: #15803d;
    }

    .admin-dashboard .employment-number.self-employed {
        color: #b45309;
    }

    .admin-dashboard .employment-number.unemployed {
        color: #b91c1c;
    }

    .admin-dashboard .employment-label {
        margin-top: 0.2rem;
        font-size: 0.74rem;
        color: #64748b;
    }

    .admin-dashboard .role-row + .role-row {
        margin-top: 0.72rem;
    }

    .admin-dashboard .role-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.32rem;
        gap: 0.4rem;
    }

    .admin-dashboard .role-name {
        font-size: 0.86rem;
        font-weight: 700;
        color: #1f2937;
        display: inline-flex;
        align-items: center;
        gap: 0.36rem;
    }

    .admin-dashboard .role-count {
        border-radius: 999px;
        padding: 0.14rem 0.45rem;
        font-size: 0.74rem;
        font-weight: 700;
    }

    .admin-dashboard .role-count.admin {
        background: #fee2e2;
        color: #991b1b;
    }

    .admin-dashboard .role-count.staff {
        background: #e0f2fe;
        color: #0c4a6e;
    }

    .admin-dashboard .role-count.alumni {
        background: #dcfce7;
        color: #166534;
    }

    .admin-dashboard .progress-track {
        width: 100%;
        height: 6px;
        border-radius: 999px;
        background: #e2e8f0;
        overflow: hidden;
    }

    .admin-dashboard .progress-fill {
        height: 100%;
        border-radius: 999px;
    }

    .admin-dashboard .progress-fill.admin {
        background: #dc2626;
    }

    .admin-dashboard .progress-fill.staff {
        background: #0891b2;
    }

    .admin-dashboard .progress-fill.alumni {
        background: #16a34a;
    }

    .admin-dashboard .user-summary {
        margin-top: 0.85rem;
        padding-top: 0.72rem;
        border-top: 1px solid #edf2fa;
        display: grid;
        gap: 0.42rem;
    }

    .admin-dashboard .user-summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.86rem;
    }

    .admin-dashboard .quick-action-grid {
        display: grid;
        grid-template-columns: repeat(1, minmax(0, 1fr));
        gap: 0.5rem;
    }

    .admin-dashboard .quick-action-link {
        border: 1px solid var(--dash-border);
        border-radius: 0.78rem;
        padding: 0.62rem 0.72rem;
        display: flex;
        align-items: center;
        gap: 0.58rem;
        color: inherit;
        text-decoration: none;
        transition: border-color 0.16s ease, transform 0.16s ease, box-shadow 0.16s ease;
    }

    .admin-dashboard .quick-action-link:hover {
        border-color: #bfd2f1;
        transform: translateX(2px);
        box-shadow: 0 8px 18px rgba(30, 64, 175, 0.08);
    }

    .admin-dashboard .quick-action-icon {
        width: 36px;
        height: 36px;
        border-radius: 0.72rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #1d4ed8;
        background: #e0ecff;
        flex-shrink: 0;
    }

    .admin-dashboard .quick-action-text {
        min-width: 0;
        flex: 1;
        line-height: 1.2;
    }

    .admin-dashboard .quick-action-title {
        display: block;
        font-size: 0.86rem;
        font-weight: 700;
        color: #0f172a;
    }

    .admin-dashboard .quick-action-meta {
        display: block;
        margin-top: 0.08rem;
        font-size: 0.76rem;
        color: #64748b;
    }

    .admin-dashboard .quick-action-arrow {
        color: #94a3b8;
        font-size: 0.95rem;
        flex-shrink: 0;
    }

    .admin-dashboard .chart-compact {
        height: 240px;
    }

    .admin-dashboard .viewport-list {
        max-height: none;
        overflow-y: visible;
        scrollbar-width: auto;
    }

    .admin-dashboard .viewport-list::-webkit-scrollbar {
        width: 6px;
    }

    .admin-dashboard .viewport-list::-webkit-scrollbar-thumb {
        background: #c8d5ea;
        border-radius: 999px;
    }

    .admin-dashboard .table-minimal {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    .admin-dashboard .table-minimal thead th {
        position: static;
        background: #f8fafd;
        border-bottom: 1px solid #e4ebf6;
        color: #64748b;
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 700;
        text-align: left;
        padding: 0.72rem 0.88rem;
        white-space: nowrap;
    }

    .admin-dashboard .table-minimal tbody td {
        padding: 0.76rem 0.88rem;
        font-size: 0.86rem;
        border-bottom: 1px solid #edf2fa;
        vertical-align: middle;
    }

    .admin-dashboard .table-minimal tbody tr:hover {
        background: #f8fbff;
    }

    .admin-dashboard .table-minimal .cell-tight {
        width: 1%;
        white-space: nowrap;
    }

    .admin-dashboard .inline-action-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.2rem;
        border-radius: 0.48rem;
        border: 1px solid #16a34a;
        background: #16a34a;
        color: #fff;
        font-size: 0.76rem;
        font-weight: 700;
        padding: 0.34rem 0.6rem;
        line-height: 1;
        text-decoration: none;
    }

    .admin-dashboard .inline-action-btn:hover {
        background: #15803d;
        border-color: #15803d;
        color: #fff;
    }

    .admin-dashboard .list-block {
        display: flex;
        flex-direction: column;
    }

    .admin-dashboard .list-row {
        padding: 0.9rem 1.1rem;
        border-bottom: 1px solid #edf2fa;
    }

    .admin-dashboard .list-row:last-child {
        border-bottom: 0;
    }

    .admin-dashboard .list-row-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.5rem;
    }

    .admin-dashboard .list-tag {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.14rem 0.48rem;
        font-size: 0.72rem;
        font-weight: 700;
        background: #eef2f9;
        color: #334155;
    }

    .admin-dashboard .list-time {
        font-size: 0.73rem;
        color: #94a3b8;
        white-space: nowrap;
    }

    .admin-dashboard .list-text {
        margin-top: 0.26rem;
        font-size: 0.82rem;
        color: #64748b;
        line-height: 1.4;
    }

    .admin-dashboard .announcement-title {
        margin: 0;
        font-size: 0.88rem;
        font-weight: 700;
        color: #0f172a;
    }

    .admin-dashboard .announcement-text {
        margin: 0.24rem 0 0;
        font-size: 0.82rem;
        color: #64748b;
        line-height: 1.45;
    }

    .admin-dashboard .course-row + .course-row {
        margin-top: 0.78rem;
    }

    .admin-dashboard .course-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        margin-bottom: 0.3rem;
    }

    .admin-dashboard .course-name {
        font-size: 0.86rem;
        font-weight: 700;
        color: #1f2937;
    }

    .admin-dashboard .course-count {
        font-size: 0.8rem;
        color: #64748b;
    }

    .admin-dashboard .empty-block {
        text-align: center;
        padding: 2rem 1rem;
        color: #64748b;
    }

    .admin-dashboard .dashboard-footnote {
        text-align: center;
        font-size: 0.75rem;
        color: #94a3b8;
        margin-top: 0.3rem;
        margin-bottom: 0.18rem;
    }

    @keyframes dashboard-enter {
        from {
            opacity: 0;
            transform: translateY(8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (min-width: 768px) {
        .admin-dashboard .metric-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .admin-dashboard .kpi-band {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .admin-dashboard .kpi-item {
            border-bottom: 0;
            border-right: 1px dashed #d5e1f4;
        }

        .admin-dashboard .kpi-item:last-child {
            border-right: 0;
        }

        .admin-dashboard .quick-action-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (min-width: 1280px) {
        .admin-dashboard .metric-grid {
            grid-template-columns: repeat(5, minmax(0, 1fr));
        }
    }

    @media (max-width: 991.98px) {
        .admin-dashboard .panel-subtitle {
            white-space: normal;
            text-align: right;
        }

        .admin-dashboard .viewport-list {
            overflow-y: visible;
        }

        .admin-dashboard .chart-compact {
            height: 270px;
        }
    }

    @media (max-width: 767.98px) {
        .admin-dashboard .hero-main {
            padding: 0.95rem 0.9rem 0.75rem;
        }

        .admin-dashboard .hero-meta {
            padding: 0.52rem 0.9rem 0.62rem;
        }

        .admin-dashboard .hero-title {
            font-size: 1.35rem;
        }

        .admin-dashboard .hero-actions {
            width: 100%;
            justify-content: flex-start;
        }

        .admin-dashboard .employment-breakdown {
            gap: 0.35rem;
        }

        .admin-dashboard .quick-action-grid {
            grid-template-columns: repeat(1, minmax(0, 1fr));
        }
    }
</style>

<section class="admin-dashboard">
    <div class="dashboard-shell">

        <div class="hero-panel card-enter">
            <div class="hero-main">
                <div class="hero-user">
                    <div class="hero-avatar">{{ app.user.firstName|first }}{{ app.user.lastName|first }}</div>
                    <div class="min-w-0">
                        <h2 class="hero-title">Admin Dashboard</h2>
                        <p class="hero-subtitle">Welcome back, <strong>{{ app.user.firstName }}</strong>. Here is your system overview.</p>
                    </div>
                </div>
                <div class="hero-actions">
                    <a href="{{ path('admin_users') }}" class="hero-btn hero-btn-soft"><i class="bi bi-people-fill"></i>Users</a>
                    <a href="{{ path('alumni_index') }}" class="hero-btn hero-btn-solid"><i class="bi bi-mortarboard-fill"></i>Alumni</a>
                </div>
            </div>
            <div class="hero-meta">
                <span><i class="bi bi-calendar3"></i>{{ 'now'|date('F d, Y') }}</span>
                <span><i class="bi bi-clock"></i>{{ 'now'|date('h:i A') }}</span>
                <span class="hero-pill"><i class="bi bi-shield-check"></i>Administrator</span>
                <span class="ml-auto"><i class="bi bi-people"></i>{{ totalAlumni }} alumni - {{ totalUsers }} users</span>
            </div>
        </div>

        {% set headlineMetrics = [
            {label: 'Total Alumni', value: totalAlumni, icon: 'bi-people-fill', tone: 'primary', note: 'Profiles tracked'},
            {label: 'Registered Users', value: totalUsers, icon: 'bi-person-check-fill', tone: 'accent', note: 'Accounts in the platform'},
            {label: 'Pending Approval', value: pendingUsers, icon: 'bi-hourglass-split', tone: pendingUsers > 0 ? 'warning' : 'accent', valueClass: pendingUsers > 0 ? 'metric-warning' : 'metric-success', note: pendingUsers > 0 ? 'Requires review' : 'Queue is clear'},
            {label: 'Active Jobs', value: activeJobs, icon: 'bi-briefcase-fill', tone: 'primary', note: 'Open opportunities'},
            {label: 'Survey Responses', value: totalSurveyResponses, icon: 'bi-clipboard-data-fill', tone: 'neutral', note: 'Latest collected data'}
        ] %}
        <div class="metric-grid">
            {% for metric in headlineMetrics %}
            <article class="metric-card card-enter">
                <div class="metric-top">
                    <div class="metric-icon {{ metric.tone }}"><i class="bi {{ metric.icon }}"></i></div>
                    <span class="metric-label">{{ metric.label }}</span>
                </div>
                <div class="metric-value {{ metric.valueClass|default('') }}">{{ metric.value }}</div>
                <p class="metric-note">{{ metric.note }}</p>
            </article>
            {% endfor %}
        </div>

        <div class="kpi-band card-enter">
            <div class="kpi-item">
                <p class="kpi-label">Alignment Rate</p>
                <div class="kpi-main">
                    <span class="kpi-value primary">{{ alignmentRate }}%</span>
                    <span class="kpi-badge primary">Job vs Degree</span>
                </div>
            </div>
            <div class="kpi-item">
                <p class="kpi-label">Queue Health</p>
                <div class="kpi-main">
                    <span class="kpi-value {{ pendingUsers > 0 ? 'warning' : 'success' }}">{{ pendingUsers }}</span>
                    <span class="kpi-badge {{ pendingUsers > 0 ? 'warning' : 'success' }}">{{ pendingUsers > 0 ? 'Needs Review' : 'Stable' }}</span>
                </div>
            </div>
            <div class="kpi-item">
                <p class="kpi-label">Active Users</p>
                <div class="kpi-main">
                    <span class="kpi-value neutral">{{ activeUsers }}</span>
                    <span class="kpi-badge primary">Online now</span>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-3">
            <div class="lg:col-span-4">
                <div class="panel-card card-enter h-full">
                    <div class="panel-head">
                        <h6 class="panel-title"><i class="bi bi-speedometer2"></i>Employment Rate</h6>
                        <span class="panel-subtitle">Current snapshot</span>
                    </div>
                    <div class="panel-body">
                        <div class="employment-ring">
                            <svg viewBox="0 0 36 36" class="w-full h-full">
                                <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#E2E8F0" stroke-width="2.8"></path>
                                <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#1D4ED8" stroke-width="2.8" stroke-dasharray="{{ employmentRate }}, 100" stroke-linecap="round"></path>
                            </svg>
                            <div class="employment-score">{{ employmentRate }}%</div>
                        </div>

                        <p class="employment-caption">of alumni are employed or self-employed.</p>

                        <div class="employment-breakdown">
                            <div>
                                <div class="employment-number employed">{{ employed }}</div>
                                <div class="employment-label">Employed</div>
                            </div>
                            <div>
                                <div class="employment-number self-employed">{{ selfEmployed }}</div>
                                <div class="employment-label">Self-Emp.</div>
                            </div>
                            <div>
                                <div class="employment-number unemployed">{{ unemployed }}</div>
                                <div class="employment-label">Unemployed</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-4">
                <div class="panel-card card-enter h-full">
                    <div class="panel-head">
                        <h6 class="panel-title"><i class="bi bi-person-lines-fill"></i>User Overview</h6>
                        <span class="panel-subtitle">Role distribution</span>
                    </div>
                    <div class="panel-body">
                        {% set roles = [
                            {icon: 'bi-shield-fill', iconCls: 'text-red-600', countCls: 'admin', fillCls: 'admin', label: 'Admins', count: adminCount},
                            {icon: 'bi-person-badge-fill', iconCls: 'text-cyan-600', countCls: 'staff', fillCls: 'staff', label: 'Staff', count: staffCount},
                            {icon: 'bi-mortarboard-fill', iconCls: 'text-green-600', countCls: 'alumni', fillCls: 'alumni', label: 'Alumni', count: studentCount}
                        ] %}
                        {% for role in roles %}
                        <div class="role-row">
                            <div class="role-top">
                                <span class="role-name"><i class="bi {{ role.icon }} {{ role.iconCls }}"></i>{{ role.label }}</span>
                                <span class="role-count {{ role.countCls }}">{{ role.count }}</span>
                            </div>
                            <div class="progress-track">
                                <div class="progress-fill {{ role.fillCls }}" style="width:{{ totalUsers > 0 ? (role.count / totalUsers * 100)|round : 0 }}%"></div>
                            </div>
                        </div>
                        {% endfor %}

                        <div class="user-summary">
                            <div class="user-summary-row">
                                <span class="text-gray-500">Total Users</span>
                                <span class="font-bold">{{ totalUsers }}</span>
                            </div>
                            <div class="user-summary-row">
                                <span class="text-gray-500">Active</span>
                                <span class="font-bold text-green-700">{{ activeUsers }}</span>
                            </div>
                        </div>

                        <a href="{{ path('admin_users') }}" class="btn-outline-norsu btn-sm w-full mt-3 font-semibold">
                            <i class="bi bi-arrow-right mr-1"></i>Manage Users
                        </a>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-4">
                <div class="panel-card card-enter h-full">
                    <div class="panel-head">
                        <h6 class="panel-title"><i class="bi bi-lightning-fill"></i>Quick Actions</h6>
                        <span class="panel-subtitle">Common shortcuts</span>
                    </div>
                    <div class="panel-body">
                        {% set actions = [
                            {path: 'alumni_index', icon: 'bi-person-plus-fill', label: 'Add Alumni', note: 'Create a new alumni profile'},
                            {path: 'alumni_index', icon: 'bi-search', label: 'Manage Alumni', note: 'Review and update records'},
                            {path: 'admin_users', icon: 'bi-people-fill', label: 'Manage Users', note: 'Access user permissions'},
                            {path: 'report_index', icon: 'bi-bar-chart-line', label: 'Reports', note: 'View analytics and exports'},
                            {path: 'admin_audit_log', icon: 'bi-journal-text', label: 'Audit Log', note: 'Check system activities'},
                            {path: 'announcement_index', icon: 'bi-megaphone-fill', label: 'Announcements', note: 'Publish platform updates'}
                        ] %}
                        <div class="quick-action-grid">
                            {% for action in actions %}
                            <a href="{{ path(action.path, action.pathParams|default({})) }}" class="quick-action-link">
                                <span class="quick-action-icon"><i class="bi {{ action.icon }}"></i></span>
                                <span class="quick-action-text">
                                    <span class="quick-action-title">{{ action.label }}</span>
                                    <span class="quick-action-meta">{{ action.note }}</span>
                                </span>
                                <i class="bi bi-chevron-right quick-action-arrow"></i>
                            </a>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="panel-card card-enter">
            <div class="panel-head">
                <h6 class="panel-title"><i class="bi bi-pie-chart-fill"></i>Employment Status Distribution</h6>
                <span class="panel-subtitle">Grouped by alumni employmentStatus</span>
            </div>
            <div class="panel-body">
                <div class="chart-compact">
                    <canvas id="employmentStatusPieChart"></canvas>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
            <div class="panel-card card-enter">
                <div class="panel-head">
                    <h6 class="panel-title"><i class="bi bi-hourglass-split"></i>Pending Approvals</h6>
                    {% if pendingUsers > 0 %}
                        <span class="badge badge-warning">{{ pendingUsers }}</span>
                    {% else %}
                        <span class="badge badge-success">All clear</span>
                    {% endif %}
                </div>
                <div class="panel-body panel-body-tight">
                    {% if pendingList|length > 0 %}
                    <div class="viewport-list">
                        <table class="table-minimal">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Registered</th>
                                    <th class="cell-tight text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for pUser in pendingList %}
                                <tr>
                                    <td class="font-semibold">{{ pUser.fullName }}</td>
                                    <td class="text-gray-500">{{ pUser.email }}</td>
                                    <td class="text-gray-500">{{ pUser.dateRegistered|date('M d, Y') }}</td>
                                    <td class="cell-tight text-right">
                                        <form method="post" action="{{ path('admin_user_approve', {id: pUser.id}) }}" class="inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ pUser.id) }}">
                                            <button class="inline-action-btn" type="submit"><i class="bi bi-check-lg"></i>Approve</button>
                                        </form>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% if pendingUsers > 5 %}
                    <div class="text-center py-2 border-t border-gray-100">
                        <a href="{{ path('admin_users') }}?status=pending" class="text-sm text-blue-700 font-semibold">View all {{ pendingUsers }} pending <i class="bi bi-arrow-right"></i></a>
                    </div>
                    {% endif %}
                    {% else %}
                    <div class="empty-block">
                        <i class="bi bi-check-circle text-green-600 text-3xl block mb-2"></i>
                        <p class="mb-0 text-sm font-medium">No pending approvals</p>
                    </div>
                    {% endif %}
                </div>
            </div>

            <div class="panel-card card-enter">
                <div class="panel-head">
                    <h6 class="panel-title"><i class="bi bi-activity"></i>Recent Activity</h6>
                    <a href="{{ path('admin_audit_log') }}" class="btn-outline-norsu btn-sm">View All</a>
                </div>
                <div class="panel-body panel-body-tight">
                    {% if recentAuditLogs|length > 0 %}
                    <div class="list-block viewport-list">
                        {% for log in recentAuditLogs %}
                        <div class="list-row">
                            <div class="list-row-top">
                                <span class="list-tag">{{ log.action }}</span>
                                <span class="list-time">{{ log.createdAt|date('M d, H:i') }}</span>
                            </div>
                            <p class="list-text">{{ log.details|default('-') }}</p>
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <div class="empty-block">
                        <i class="bi bi-journal text-gray-400 text-3xl block mb-2"></i>
                        <p class="mb-0 text-sm font-medium">No recent activity</p>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {% if recentAnnouncements|length > 0 %}
        <div class="panel-card card-enter">
            <div class="panel-head">
                <h6 class="panel-title"><i class="bi bi-megaphone-fill"></i>Latest Announcements</h6>
                <a href="{{ path('announcement_index') }}" class="btn-outline-norsu btn-sm">View All</a>
            </div>
            <div class="panel-body panel-body-tight">
                <div class="list-block viewport-list">
                    {% for ann in recentAnnouncements %}
                    <div class="list-row">
                        <div class="list-row-top">
                            <h6 class="announcement-title">{{ ann.title }}</h6>
                            <span class="list-tag">{{ ann.datePosted|date('M d') }}</span>
                        </div>
                        <p class="announcement-text">{{ ann.description|length > 150 ? ann.description|slice(0, 150) ~ '...' : ann.description }}</p>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endif %}

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-3">
            <div class="lg:col-span-8">
                <div class="panel-card card-enter">
                    <div class="panel-head">
                        <h6 class="panel-title"><i class="bi bi-clock-history"></i>Recently Added Alumni</h6>
                        <a href="{{ path('alumni_index') }}" class="btn-outline-norsu btn-sm">View All</a>
                    </div>
                    <div class="panel-body panel-body-tight">
                        <div class="viewport-list">
                            <table class="table-minimal">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Course</th>
                                        <th>Year</th>
                                        <th>Status</th>
                                        <th class="cell-tight text-right">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for alumni in recentAlumni %}
                                    <tr>
                                        <td>
                                            <div class="font-semibold">{{ alumni.lastName }}, {{ alumni.firstName }}</div>
                                            <span class="text-gray-500 text-[0.7rem]">{{ alumni.studentNumber }}</span>
                                        </td>
                                        <td>{{ alumni.course }}</td>
                                        <td>{{ alumni.yearGraduated ?? 'N/A' }}</td>
                                        <td>
                                            {% if alumni.employmentStatus == 'Employed' %}
                                                <span class="badge badge-employed">Employed</span>
                                            {% elseif alumni.employmentStatus == 'Unemployed' %}
                                                <span class="badge badge-unemployed">Unemployed</span>
                                            {% elseif alumni.employmentStatus == 'Self-Employed' %}
                                                <span class="badge badge-self-employed">Self-Employed</span>
                                            {% else %}
                                                <span class="badge badge-secondary">{{ alumni.employmentStatus ?? 'N/A' }}</span>
                                            {% endif %}
                                        </td>
                                        <td class="cell-tight text-right">
                                            <div class="flex justify-end gap-1">
                                                <a href="{{ path('alumni_show', {id: alumni.id}) }}" class="btn-outline-norsu btn-xs" title="View"><i class="bi bi-eye"></i></a>
                                                <a href="{{ path('alumni_edit', {id: alumni.id}) }}" class="btn-warning btn-xs" title="Edit"><i class="bi bi-pencil"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                    {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center text-gray-500 py-8">
                                            No alumni records yet. <a href="{{ path('alumni_index') }}#addAlumniSection" onclick="setTimeout(function(){var s=document.getElementById('addAlumniSection');if(s)s.classList.remove('hidden')},100)">Add the first one</a>.
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-4">
                <div class="panel-card card-enter h-full">
                    <div class="panel-head">
                        <h6 class="panel-title"><i class="bi bi-mortarboard-fill"></i>Top Courses</h6>
                        <span class="panel-subtitle">Most represented programs</span>
                    </div>
                    <div class="panel-body">
                        {% if courseStats|length > 0 %}
                            {% set maxTotal = courseStats[0].total %}
                            {% for stat in courseStats %}
                            <div class="course-row">
                                <div class="course-head">
                                    <span class="course-name">{{ stat.course }}</span>
                                    <span class="course-count">{{ stat.total }}</span>
                                </div>
                                <div class="progress-track">
                                    <div class="progress-fill" style="width:{{ (stat.total / maxTotal * 100)|round }}%; background:#1d4ed8;"></div>
                                </div>
                            </div>
                            {% endfor %}
                        {% else %}
                            <div class="empty-block">
                                <i class="bi bi-mortarboard text-gray-400 text-3xl block mb-2"></i>
                                <p class="mb-0 text-sm">No course data yet</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <div class="dashboard-footnote">&copy; {{ 'now'|date('Y') }} NORSU Alumni Tracker</div>
    </div>
</section>

<script>
    document.addEventListener('turbo:load', function () {
        const canvas = document.getElementById('employmentStatusPieChart');
        if (!canvas || typeof Chart === 'undefined') {
            return;
        }

        const chartPayload = {{ employmentStatusChart|json_encode|raw }};
        const labels = chartPayload.labels || [];
        const values = chartPayload.values || [];

        if (!labels.length || !values.length) {
            return;
        }

        if (window.employmentStatusPieChartInstance) {
            window.employmentStatusPieChartInstance.destroy();
        }

        window.employmentStatusPieChartInstance = new Chart(canvas, {
            type: 'pie',
            data: {
                labels: labels,
                datasets: [{
                    data: values,
                    backgroundColor: [
                        '#1E40AF',
                        '#2563EB',
                        '#059669',
                        '#0D9488',
                        '#F59E0B',
                        '#64748B',
                        '#DC2626'
                    ],
                    borderColor: '#FFFFFF',
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                const label = context.label || '';
                                const value = context.parsed || 0;
                                return label + ': ' + value;
                            }
                        }
                    }
                }
            }
        });
    });
</script>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
{% endblock %}
