{% extends 'base.html.twig' %}

{% block title %}Audit Log Entry{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto">
    <div class="flex items-center justify-between mb-4">
        <h4 class="font-bold text-xl mb-0"><i class="bi bi-journal-text mr-2"></i>Audit Log Entry</h4>
        <a href="{{ path('admin_audit_log') }}" class="btn-secondary btn-sm"><i class="bi bi-arrow-left mr-1"></i>Back to Audit Log</a>
    </div>

    <div class="card">
        <div class="card-body">
            <dl class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                <div>
                    <dt class="font-semibold text-gray-500">Timestamp</dt>
                    <dd>{{ log.createdAt|date('M d, Y H:i:s') }}</dd>
                </div>
                <div>
                    <dt class="font-semibold text-gray-500">Performed By</dt>
                    <dd>{{ log.performedBy.fullName }} ({{ log.performedBy.email }})</dd>
                </div>
                <div>
                    <dt class="font-semibold text-gray-500">Action</dt>
                    <dd>{{ log.actionLabel }}</dd>
                </div>
                <div>
                    <dt class="font-semibold text-gray-500">Raw Action Key</dt>
                    <dd>{{ log.action }}</dd>
                </div>
                <div>
                    <dt class="font-semibold text-gray-500">Entity</dt>
                    <dd>{{ log.entityType }}{% if log.entityId %} #{{ log.entityId }}{% endif %}</dd>
                </div>
                <div>
                    <dt class="font-semibold text-gray-500">IP Address</dt>
                    <dd>{{ log.ipAddress ?? '—' }}</dd>
                </div>
                <div class="md:col-span-2">
                    <dt class="font-semibold text-gray-500">Details</dt>
                    <dd class="whitespace-pre-wrap">{{ log.details ?? '—' }}</dd>
                </div>
            </dl>

            {% if is_granted('ROLE_ADMIN') %}
            <div class="mt-4 pt-3 border-t border-gray-200">
                <form method="post" action="{{ path('admin_audit_log_delete', {id: log.id}) }}" onsubmit="return confirm('Delete this log entry?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('audit_delete_' ~ log.id) }}">
                    <button type="submit" class="inline-flex items-center gap-1 bg-red-100 text-red-700 hover:bg-red-200 text-sm font-semibold px-3 py-2 rounded-lg transition">
                        <i class="bi bi-trash"></i>Delete Entry
                    </button>
                </form>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
