{% extends 'base.html.twig' %}

{% block title %}{{ isEdit ? 'Edit GTS Question' : 'Add GTS Question' }}{% endblock %}

{% block body %}
{% set questionIndexRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_questions_index' : 'staff_gts_questions_index' %}
<div class="mx-auto max-w-3xl">
    <div class="mb-5 flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-900">{{ isEdit ? 'Edit GTS Question' : 'Add GTS Question' }}</h1>
        <a href="{{ path(questionIndexRoute) }}" class="btn-secondary btn-sm"><i class="bi bi-arrow-left mr-1"></i>Back</a>
    </div>

    <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
        {{ form_start(form, { attr: { class: 'space-y-4' } }) }}
            <div>
                {{ form_label(form.section, null, { label_attr: { class: 'mb-1 block text-sm font-semibold text-gray-700' } }) }}
                {{ form_widget(form.section) }}
                <div class="mt-1 text-sm text-red-600">{{ form_errors(form.section) }}</div>
            </div>

            <div>
                {{ form_label(form.questionText, null, { label_attr: { class: 'mb-1 block text-sm font-semibold text-gray-700' } }) }}
                {{ form_widget(form.questionText) }}
                <div class="mt-1 text-sm text-red-600">{{ form_errors(form.questionText) }}</div>
            </div>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <div>
                    {{ form_label(form.inputType, null, { label_attr: { class: 'mb-1 block text-sm font-semibold text-gray-700' } }) }}
                    {{ form_widget(form.inputType) }}
                </div>
                <div>
                    {{ form_label(form.sortOrder, null, { label_attr: { class: 'mb-1 block text-sm font-semibold text-gray-700' } }) }}
                    {{ form_widget(form.sortOrder) }}
                </div>
            </div>

            <div>
                {{ form_label(form.optionsCsv, null, { label_attr: { class: 'mb-1 block text-sm font-semibold text-gray-700' } }) }}
                {{ form_widget(form.optionsCsv) }}
                <p class="mt-1 text-xs text-gray-500">Use this only for radio/checkbox/select question types.</p>
            </div>

            <div class="rounded-lg bg-gray-50 px-3 py-2">
                <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                    {{ form_widget(form.isActive) }}
                    <span>Active question</span>
                </label>
            </div>

            <div class="flex justify-end gap-2 pt-2">
                <a href="{{ path(questionIndexRoute) }}" class="btn-secondary">Cancel</a>
                <button type="submit" class="btn-norsu">{{ isEdit ? 'Update Question' : 'Save Question' }}</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
