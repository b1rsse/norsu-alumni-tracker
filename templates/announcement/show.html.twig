{% extends 'base.html.twig' %}

{% block title %}{{ announcement.title }}{% endblock %}

{% block body %}
<div class="flex justify-between items-center mb-3">
    <a href="{{ path('announcement_index') }}" class="btn-outline-norsu btn-sm no-print"><i class="bi bi-arrow-left mr-1"></i>Back</a>
    <div class="flex items-center gap-2 no-print">
        <button onclick="window.print()" class="inline-flex items-center gap-1 bg-gray-600 hover:bg-gray-700 text-white text-sm font-semibold px-3 py-2 rounded-lg transition">
            <i class="bi bi-printer"></i>Print
        </button>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('announcement_edit', {id: announcement.id}) }}" class="btn-norsu btn-sm"><i class="bi bi-pencil mr-1"></i>Edit</a>
        {% endif %}
    </div>
</div>

{# ── Print-only header ── #}
<div class="hidden print-header" style="display:none">
    <div style="text-align:center; margin-bottom:20px;">
        <h2 style="margin:0; font-size:18pt; font-weight:bold;">Negros Oriental State University</h2>
        <h3 style="margin:4px 0; font-size:14pt;">Announcement</h3>
        <hr style="margin-top:10px;">
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="mb-3">
            {% if announcement.category %}
                <span class="badge bg-gray-100 text-gray-700">{{ announcement.category }}</span>
            {% endif %}
            {% if not announcement.isActive %}
                <span class="badge badge-secondary">Draft</span>
            {% endif %}
            <span class="text-gray-500 text-sm ml-2">{{ announcement.datePosted|date('F d, Y \\a\\t h:i A') }}</span>
        </div>
        <h3 class="font-bold mb-3">{{ announcement.title }}</h3>
        <div class="mb-3" style="white-space: pre-line;">{{ announcement.description }}</div>
        {% if announcement.postedBy %}
            <hr class="my-3 border-gray-200">
            <span class="text-gray-500 text-sm">Posted by <strong>{{ announcement.postedBy.fullName }}</strong></span>
        {% endif %}
    </div>
</div>
{% endblock %}
