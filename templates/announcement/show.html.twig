{% extends 'base.html.twig' %}

{% block title %}{{ announcement.title }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <a href="{{ path('announcement_index') }}" class="btn btn-outline-norsu btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('announcement_edit', {id: announcement.id}) }}" class="btn btn-norsu btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
    {% endif %}
</div>

<div class="card">
    <div class="card-body">
        <div class="mb-3">
            {% if announcement.category %}
                <span class="badge bg-light text-dark">{{ announcement.category }}</span>
            {% endif %}
            {% if not announcement.isActive %}
                <span class="badge bg-secondary">Draft</span>
            {% endif %}
            <small class="text-muted ms-2">{{ announcement.datePosted|date('F d, Y \\a\\t h:i A') }}</small>
        </div>
        <h3 class="fw-bold mb-3">{{ announcement.title }}</h3>
        <div class="mb-3" style="white-space: pre-line;">{{ announcement.description }}</div>
        {% if announcement.postedBy %}
            <hr>
            <small class="text-muted">Posted by <strong>{{ announcement.postedBy.fullName }}</strong></small>
        {% endif %}
    </div>
</div>
{% endblock %}
