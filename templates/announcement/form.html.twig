{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">{{ title }}</h4>
    <a href="{{ path('announcement_index') }}" class="btn btn-outline-norsu"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="card">
    <div class="card-body">
        {{ form_start(form) }}
            <div class="row g-3">
                <div class="col-md-8">{{ form_row(form.title) }}</div>
                <div class="col-md-4">{{ form_row(form.category) }}</div>
                <div class="col-12">{{ form_row(form.description) }}</div>
                <div class="col-md-4">{{ form_row(form.isActive) }}</div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-norsu"><i class="bi bi-check-lg me-1"></i>Save Announcement</button>
                <a href="{{ path('announcement_index') }}" class="btn btn-outline-secondary">Cancel</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
