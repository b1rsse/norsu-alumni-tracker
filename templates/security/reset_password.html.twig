{% extends 'base.html.twig' %}

{% block title %}Reset Password — NORSU Alumni Tracker{% endblock %}

{% block body_class %}no-navbar{% endblock %}

{% block body %}
{% include 'security/_auth_flow_styles.html.twig' %}

<div class="auth-flow-scene">
    <div class="auth-flow-wrap">
        <div class="auth-flow-brand">
            <div class="auth-flow-badge">
                <img src="{{ asset('images/norsu-logo.webp') }}" alt="NORSU">
            </div>
            <h1>Reset Password</h1>
            <p>Set a new secure password for your account.</p>
        </div>

        <section class="auth-flow-card">
            {% for message in app.flashes('danger') %}
                <div class="auth-flow-msg error">
                    <i class="bi bi-exclamation-triangle mr-1"></i>{{ message }}
                </div>
            {% endfor %}

            <form method="post" class="auth-flow-form">
                <div class="field">
                    <label for="inputPassword" class="auth-flow-label">New Password</label>
                    <div class="auth-flow-input-wrap">
                        <i class="bi bi-lock"></i>
                        <input type="password"
                               name="password"
                               id="inputPassword"
                               class="auth-flow-input password-has-toggle"
                               autocomplete="new-password"
                               required
                               autofocus
                               placeholder="Min. 8 characters">
                        <button type="button" class="password-toggle-btn" tabindex="-1">
                            <i class="bi bi-eye-slash"></i>
                        </button>
                    </div>
                    <p class="auth-flow-help">Must include uppercase, lowercase, number, and special character.</p>
                </div>

                <div class="field">
                    <label for="inputConfirmPassword" class="auth-flow-label">Confirm Password</label>
                    <div class="auth-flow-input-wrap">
                        <i class="bi bi-lock-fill"></i>
                        <input type="password"
                               name="confirm_password"
                               id="inputConfirmPassword"
                               class="auth-flow-input password-has-toggle"
                               autocomplete="new-password"
                               required
                               placeholder="Repeat your password">
                        <button type="button" class="password-toggle-btn" tabindex="-1">
                            <i class="bi bi-eye-slash"></i>
                        </button>
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('reset_password') }}">

                <button class="auth-flow-btn" type="submit">
                    <i class="bi bi-check-circle mr-1"></i>Reset Password
                </button>

                <a href="{{ path('app_login') }}" class="auth-flow-link">
                    <i class="bi bi-arrow-left mr-1"></i>Back to Sign In
                </a>
            </form>
        </section>

        <a href="{{ path('app_home') }}" class="auth-flow-back">
            <i class="bi bi-house-fill"></i>Back to Home
        </a>
    </div>
</div>
{% endblock %}
