{% extends 'base.html.twig' %}

{% block title %}Log in{% endblock %}

{% block body_class %}no-navbar{% endblock %}

{% block body %}
<style>
    .login-mobile-scene {
        min-height: 100vh;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        font-family: Sora, Manrope, sans-serif;
        background-color: #081845;
        background-image:
            linear-gradient(132deg, rgba(7, 22, 63, 0.88) 0%, rgba(12, 52, 120, 0.72) 45%, rgba(5, 132, 124, 0.62) 100%),
            url('{{ asset('images/home-hero-graduation.png') }}');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .login-mobile-scene::before,
    .login-mobile-scene::after {
        content: "";
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
    }

    .login-mobile-scene::before {
        width: 360px;
        height: 360px;
        left: -180px;
        top: 55%;
        background: radial-gradient(circle at 50% 50%, rgba(94, 148, 255, 0.25), rgba(94, 148, 255, 0));
    }

    .login-mobile-scene::after {
        width: 340px;
        height: 340px;
        right: -150px;
        bottom: -110px;
        background: radial-gradient(circle at 50% 50%, rgba(26, 70, 162, 0.34), rgba(26, 70, 162, 0));
    }

    .login-mobile-wrap {
        width: min(560px, 100%);
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.15rem;
    }

    .login-mobile-brand {
        text-align: center;
        color: #f8fbff;
    }

    .brand-badge {
        width: 92px;
        height: 92px;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.94);
        padding: 8px;
        margin: 0 auto 0.9rem;
        box-shadow: 0 16px 32px rgba(6, 18, 48, 0.36);
    }

    .brand-badge img {
        width: 100%;
        height: 100%;
        border-radius: 18px;
        object-fit: cover;
    }

    .login-mobile-brand h1 {
        margin: 0;
        font-size: clamp(1.5rem, 4vw, 2.1rem);
        font-weight: 800;
    }

    .login-mobile-brand p {
        margin: 0.45rem 0 0;
        color: rgba(232, 242, 255, 0.9);
        font-size: 1rem;
    }

    .login-mobile-card {
        width: 100%;
        border-radius: 2rem;
        background: rgba(255, 255, 255, 0.94);
        border: 1px solid rgba(255, 255, 255, 0.52);
        box-shadow: 0 24px 44px rgba(3, 14, 44, 0.38);
        padding: 1.5rem;
        backdrop-filter: blur(2px);
        -webkit-backdrop-filter: blur(2px);
    }

    .login-switch {
        border-radius: 1rem;
        background: #e8edf5;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.35rem;
        padding: 0.35rem;
        margin-bottom: 1.05rem;
    }

    .switch-btn {
        border: 0;
        border-radius: 0.8rem;
        background: transparent;
        color: #607693;
        text-decoration: none;
        text-align: center;
        font-size: 1.02rem;
        font-weight: 700;
        padding: 0.72rem 0.65rem;
        line-height: 1;
    }

    .switch-btn.is-active {
        background: #ffffff;
        color: #16223b;
        box-shadow: 0 6px 14px rgba(31, 47, 86, 0.18);
    }

    .auth-msg {
        border-radius: 0.95rem;
        padding: 0.75rem 0.85rem;
        font-size: 0.84rem;
        margin-bottom: 0.75rem;
    }

    .auth-msg.error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #b91c1c;
    }

    .auth-msg.success {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #166534;
    }

    .login-mobile-form .field {
        margin-bottom: 0.85rem;
    }

    .login-mobile-input {
        width: 100%;
        height: 56px;
        border-radius: 1.2rem;
        border: 1px solid #d3dce8;
        background: #f8fbff;
        color: #122038;
        font-size: 1.05rem;
        padding: 0 1.1rem;
        outline: none;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .login-mobile-input::placeholder {
        color: #8ca0bb;
        opacity: 1;
    }

    .login-mobile-input:focus {
        border-color: #3f72da;
        box-shadow: 0 0 0 3px rgba(63, 114, 218, 0.2);
    }

    .password-field-wrap {
        position: relative;
    }

    .password-field-wrap .login-mobile-input {
        padding-right: 3.2rem;
    }

    .password-field-wrap .password-toggle-btn {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        border: 0;
        background: transparent;
        color: #8ba0ba;
        font-size: 1.2rem;
        padding: 0;
        line-height: 1;
    }

    .remember-row {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        color: #5f7391;
        font-size: 1.05rem;
        margin: 0.45rem 0 1.15rem;
    }

    .remember-row input {
        width: 1.35rem;
        height: 1.35rem;
        border-radius: 0.35rem;
        border: 1px solid #b9c6d9;
        accent-color: #1f3b88;
    }

    .login-primary-btn {
        width: 100%;
        border: 0;
        border-radius: 1.2rem;
        background: linear-gradient(100deg, #223267 0%, #1f2f61 62%, #162650 100%);
        color: #ffffff;
        font-size: 1.9rem;
        font-weight: 700;
        padding: 0.92rem 1rem;
        box-shadow: 0 14px 24px rgba(19, 33, 74, 0.28);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .login-primary-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 18px 30px rgba(16, 28, 65, 0.34);
    }

    .login-divider {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #8b9cb6;
        margin: 1.25rem 0;
        font-size: 1rem;
        font-weight: 700;
    }

    .login-divider::before,
    .login-divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background: #d8e0ec;
    }

    .login-google-btn {
        width: 100%;
        border-radius: 1.2rem;
        border: 1px solid #d3dce8;
        background: #ffffff;
        color: #1b2740;
        font-size: 1.05rem;
        font-weight: 600;
        padding: 0.95rem 1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.7rem;
        cursor: pointer;
        opacity: 1;
        text-decoration: none;
        transition: border-color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
    }

    .login-google-btn:hover {
        border-color: #b9c8df;
        background: #f8fbff;
        transform: translateY(-1px);
    }

    .google-glyph {
        width: 1.45rem;
        height: 1.45rem;
        border-radius: 50%;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        color: #ea4335;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: Arial, sans-serif;
    }

    .login-meta-link {
        display: block;
        text-align: center;
        margin-top: 1.2rem;
        color: #5d7290;
        text-decoration: none;
        font-size: 1.05rem;
    }

    .login-meta-link:hover {
        color: #32496d;
    }

    .back-home-link {
        color: #f3f7ff;
        text-decoration: none;
        font-weight: 600;
        font-size: 1.08rem;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.2rem 0.25rem;
    }

    .back-home-link:hover {
        color: #ffffff;
    }

    .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    @media (max-width: 640px) {
        .login-mobile-card {
            border-radius: 1.8rem;
            padding: 1.2rem;
        }

        .brand-badge {
            width: 84px;
            height: 84px;
            border-radius: 20px;
        }

        .login-mobile-brand h1 {
            font-size: 1.9rem;
        }
    }
</style>

<div class="login-mobile-scene">
    <div class="login-mobile-wrap">
        <div class="login-mobile-brand">
            <div class="brand-badge">
                <img src="{{ asset('images/norsu-logo.webp') }}" alt="NORSU logo">
            </div>
            <h1>NORSU Alumni Network</h1>
            <p>Connect with fellow alumni and stay updated</p>
        </div>

        <section class="login-mobile-card" aria-label="Login form">
            <div class="login-switch" role="tablist" aria-label="Authentication options">
                <button type="button" class="switch-btn is-active" role="tab" aria-selected="true">Login</button>
                <a href="{{ path('app_register') }}" class="switch-btn" role="tab" aria-selected="false">Sign Up</a>
            </div>

            {% if error %}
                <div class="auth-msg error">
                    <i class="bi bi-exclamation-triangle mr-1"></i>{{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% for message in app.flashes('success') %}
                <div class="auth-msg success">
                    <i class="bi bi-check-circle mr-1"></i>{{ message }}
                </div>
            {% endfor %}

            <form method="post" class="login-mobile-form">
                <div class="field">
                    <label for="inputEmail" class="visually-hidden">Email Address</label>
                    <input type="email"
                           value="{{ last_username }}"
                           name="_username"
                           id="inputEmail"
                           class="login-mobile-input"
                           autocomplete="email"
                           placeholder="Email Address"
                           required
                           autofocus>
                </div>

                <div class="field password-field-wrap">
                    <label for="inputPassword" class="visually-hidden">Password</label>
                    <input type="password"
                           name="_password"
                           id="inputPassword"
                           class="login-mobile-input"
                           autocomplete="current-password"
                           placeholder="Password"
                           required>
                    <button type="button" class="password-toggle-btn" tabindex="-1" aria-label="Toggle password visibility">
                        <i class="bi bi-eye-slash"></i>
                    </button>
                </div>

                <div class="remember-row">
                    <input type="checkbox" id="remember_me" name="_remember_me" value="on">
                    <label for="remember_me">Remember me</label>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button class="login-primary-btn" type="submit">Sign In</button>
            </form>

            <div class="login-divider">or</div>

            <a href="{{ path('app_google_start') }}" class="login-google-btn" title="Continue with Google">
                <span class="google-glyph">G</span>
                Continue with Google
            </a>

            <a href="{{ path('app_forgot_password') }}" class="login-meta-link">Forgot your password?</a>
        </section>

        <a href="{{ path('app_home') }}" class="back-home-link">
            <i class="bi bi-house-fill"></i>
            Back to Home
        </a>
    </div>
</div>
{% endblock %}
