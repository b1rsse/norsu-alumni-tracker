<div style="max-width:600px;margin:0 auto;font-family:Arial,sans-serif;color:#333">
    <div style="text-align:center;padding:24px 0 16px">
        <h2 style="margin:0 0 4px;color:#1e40af">NORSU Alumni Tracker</h2>
        <p style="margin:0;color:#6b7280;font-size:14px">Password Reset Request</p>
    </div>

    <div style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:24px">
        <p style="margin:0 0 16px">Hi <strong>{{ user.firstName }}</strong>,</p>

        <p style="margin:0 0 16px">We received a request to reset your password. Click the button below to choose a new one:</p>

        <div style="text-align:center;margin:24px 0">
            <a href="{{ resetUrl }}" style="display:inline-block;background:#1e40af;color:#fff;padding:12px 32px;border-radius:6px;text-decoration:none;font-weight:bold">
                Reset My Password
            </a>
        </div>

        <p style="margin:0 0 8px;font-size:13px;color:#6b7280">This link will expire in <strong>{{ tokenLifetime }} hour{{ tokenLifetime > 1 ? 's' : '' }}</strong>.</p>
        <p style="margin:0 0 8px;font-size:13px;color:#6b7280">If you didn't request this, you can safely ignore this email.</p>

        <hr style="border:none;border-top:1px solid #e5e7eb;margin:16px 0">

        <p style="margin:0;font-size:12px;color:#9ca3af">If the button doesn't work, copy and paste this link into your browser:</p>
        <p style="margin:4px 0 0;font-size:12px;color:#1e40af;word-break:break-all">{{ resetUrl }}</p>
    </div>

    <div style="text-align:center;padding:16px 0;font-size:12px;color:#9ca3af">
        &copy; {{ 'now'|date('Y') }} Negros Oriental State University
    </div>
</div>
