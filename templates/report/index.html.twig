{% extends 'base.html.twig' %}

{% block title %}Reports & Analytics{% endblock %}

{% block body %}
<h4 class="fw-bold mb-4"><i class="bi bi-bar-chart-fill me-2"></i>Reports & Analytics</h4>

{# ── Summary Cards ── #}
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card stat-card"><div class="card-body text-center">
            <div class="stat-value">{{ totalAlumni }}</div>
            <div class="stat-label">Total Alumni</div>
        </div></div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card"><div class="card-body text-center">
            <div class="stat-value" style="color:#059669">{{ employed }}</div>
            <div class="stat-label">Employed</div>
        </div></div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card"><div class="card-body text-center">
            <div class="stat-value" style="color:var(--norsu-gold)">{{ selfEmployed }}</div>
            <div class="stat-label">Self-Employed</div>
        </div></div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card"><div class="card-body text-center">
            <div class="stat-value" style="color:#DC2626">{{ unemployed }}</div>
            <div class="stat-label">Unemployed</div>
        </div></div>
    </div>
</div>

<div class="row g-4">
    {# ── Employment Rate by Course ── #}
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-mortarboard me-1"></i> Employment Rate by Course</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr><th class="ps-3">Course</th><th>Total</th><th>Employed</th><th>Rate</th><th>Bar</th></tr>
                        </thead>
                        <tbody>
                            {% for row in courseEmployment %}
                            {% set rate = row.total > 0 ? (row.employedCount / row.total * 100)|round(1) : 0 %}
                            <tr>
                                <td class="ps-3 fw-semibold">{{ row.course }}</td>
                                <td>{{ row.total }}</td>
                                <td>{{ row.employedCount }}</td>
                                <td>{{ rate }}%</td>
                                <td style="width:30%">
                                    <div class="progress" style="height:8px">
                                        <div class="progress-bar" style="width:{{ rate }}%;background:var(--norsu-green)"></div>
                                    </div>
                                </td>
                            </tr>
                            {% else %}
                            <tr><td colspan="5" class="text-center text-muted py-3">No data.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    {# ── Local vs Abroad + Job Relevance ── #}
    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-globe2 me-1"></i> Work Location</div>
            <div class="card-body text-center">
                <div class="row">
                    <div class="col-6">
                        <div class="fs-2 fw-bold" style="color:var(--norsu-green)">{{ workLocal }}</div>
                        <small class="text-muted">Local</small>
                    </div>
                    <div class="col-6">
                        <div class="fs-2 fw-bold" style="color:var(--norsu-gold)">{{ workAbroad }}</div>
                        <small class="text-muted">Abroad</small>
                    </div>
                </div>
                {% if totalAlumni > 0 %}
                <div class="progress mt-3" style="height:10px">
                    <div class="progress-bar" style="width:{{ (workLocal/totalAlumni*100)|round }}%;background:var(--norsu-green)"></div>
                    <div class="progress-bar" style="width:{{ (workAbroad/totalAlumni*100)|round }}%;background:var(--norsu-gold)"></div>
                </div>
                {% endif %}
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-link-45deg me-1"></i> Job-Course Relevance</div>
            <div class="card-body text-center">
                <div class="row">
                    <div class="col-6">
                        <div class="fs-2 fw-bold" style="color:#059669">{{ jobRelated }}</div>
                        <small class="text-muted">Related</small>
                    </div>
                    <div class="col-6">
                        <div class="fs-2 fw-bold" style="color:#DC2626">{{ jobNotRelated }}</div>
                        <small class="text-muted">Not Related</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    {# ── Salary Distribution ── #}
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-currency-exchange me-1"></i> Salary Distribution</div>
            <div class="card-body">
                {% if salaryDistribution|length > 0 %}
                    {% for row in salaryDistribution %}
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1 small">
                            <span class="fw-semibold">{{ row.monthlySalary }}</span>
                            <span class="text-muted">{{ row.total }} alumni</span>
                        </div>
                        <div class="progress" style="height:8px">
                            <div class="progress-bar" style="width:{{ (row.total / totalAlumni * 100)|round }}%;background:var(--norsu-gold)"></div>
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <p class="text-muted text-center mb-0">No salary data available.</p>
                {% endif %}
            </div>
        </div>
    </div>

    {# ── Graduates per Year ── #}
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-calendar3 me-1"></i> Graduates per Year</div>
            <div class="card-body">
                {% if yearDistribution|length > 0 %}
                    {% set maxYear = yearDistribution[0].total %}
                    {% for row in yearDistribution %}
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1 small">
                            <span class="fw-semibold">{{ row.yearGraduated }}</span>
                            <span class="text-muted">{{ row.total }} alumni</span>
                        </div>
                        <div class="progress" style="height:8px">
                            <div class="progress-bar" style="width:{{ (row.total / maxYear * 100)|round }}%;background:var(--norsu-green)"></div>
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <p class="text-muted text-center mb-0">No year data available.</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# ── Province Distribution ── #}
<div class="row g-4 mt-1">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-pin-map me-1"></i> Alumni by Province</div>
            <div class="card-body">
                {% if provinceDistribution|length > 0 %}
                    <div class="row">
                        {% for row in provinceDistribution %}
                        <div class="col-md-6 mb-3">
                            <div class="d-flex justify-content-between mb-1 small">
                                <span class="fw-semibold">{{ row.province }}</span>
                                <span class="text-muted">{{ row.total }}</span>
                            </div>
                            {% set maxProv = provinceDistribution[0].total %}
                            <div class="progress" style="height:8px">
                                <div class="progress-bar" style="width:{{ (row.total / maxProv * 100)|round }}%;background:#7C3AED"></div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="text-muted text-center mb-0">No province data available.</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
