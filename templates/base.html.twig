<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}NORSU Alumni Tracker{% endblock %}</title>
        <link rel="icon" type="image/webp" href="{{ asset('images/norsu-logo.webp') }}">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="{% block body_class %}{% endblock %}">
        {# ── TOP NAVBAR ── #}
        <nav class="navbar navbar-expand-lg navbar-dark navbar-norsu fixed-top">
            <div class="container-fluid px-3">
                {% if app.user %}
                <button class="btn btn-link text-white d-lg-none me-2 p-0" id="sidebarToggle" type="button">
                    <i class="bi bi-list fs-4"></i>
                </button>
                {% endif %}
                <a class="navbar-brand" href="{{ path('app_home') }}">
                    <span class="brand-icon"><img src="{{ asset('images/norsu-logo.webp') }}" alt="NORSU Logo" class="brand-logo-img"></span>
                    <span>
                        NORSU Alumni Tracker
                        <span class="brand-text-sub">Negros Oriental State University</span>
                    </span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        {% if app.user %}
                            <li class="nav-item d-flex align-items-center">
                                <span class="nav-link nav-user d-flex align-items-center gap-2">
                                    <span style="width:30px;height:30px;border-radius:50%;background:rgba(255,255,255,0.2);display:inline-flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700">{{ app.user.firstName|first }}{{ app.user.lastName|first }}</span>
                                    {{ app.user.firstName }}
                                    {% if is_granted('ROLE_ADMIN') %}
                                        <span class="badge bg-success" style="font-size:0.6rem">Admin</span>
                                    {% endif %}
                                </span>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_login') }}"><i class="bi bi-box-arrow-in-right me-1"></i>Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-norsu-gold btn-sm ms-2 mt-1" href="{{ path('app_register') }}">Register</a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        {% if app.user %}
        {# ── SIDEBAR (only for logged-in users) ── #}
        <div class="sidebar-backdrop" id="sidebarBackdrop"></div>
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">Main Menu</div>
            <nav class="nav flex-column">
                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}"
                   href="{{ path('app_home') }}">
                    <i class="bi bi-speedometer2 sidebar-icon"></i> Dashboard
                </a>
                <a class="nav-link {% if 'alumni_' in app.request.attributes.get('_route')|default('') and app.request.attributes.get('_route') != 'alumni_create' %}active{% endif %}"
                   href="{{ path('alumni_index') }}">
                    <i class="bi bi-people-fill sidebar-icon"></i> Alumni Directory
                </a>
                <a class="nav-link {% if app.request.attributes.get('_route') == 'alumni_create' %}active{% endif %}"
                   href="{{ path('alumni_create') }}">
                    <i class="bi bi-person-plus-fill sidebar-icon"></i> Add Alumni
                </a>
                <a class="nav-link {% if 'announcement_' in app.request.attributes.get('_route')|default('') %}active{% endif %}"
                   href="{{ path('announcement_index') }}">
                    <i class="bi bi-megaphone-fill sidebar-icon"></i> Announcements
                </a>
                <a class="nav-link {% if app.request.attributes.get('_route') == 'feedback_submit' %}active{% endif %}"
                   href="{{ path('feedback_submit') }}">
                    <i class="bi bi-chat-dots sidebar-icon"></i> Submit Feedback
                </a>
                <a class="nav-link {% if 'report_' in app.request.attributes.get('_route')|default('') %}active{% endif %}"
                   href="{{ path('report_index') }}">
                    <i class="bi bi-clipboard-data sidebar-icon"></i> Reports
                </a>
            </nav>

            {% if is_granted('ROLE_ADMIN') %}
            <div class="sidebar-header">Administration</div>
            <nav class="nav flex-column">
                <a class="nav-link {% if 'report_' in app.request.attributes.get('_route')|default('') %}active{% endif %}"
                   href="{{ path('report_index') }}">
                    <i class="bi bi-clipboard-data sidebar-icon"></i> Reports
                </a>
                <a class="nav-link {% if 'feedback_index' == app.request.attributes.get('_route') or 'feedback_show' == app.request.attributes.get('_route') %}active{% endif %}"
                   href="{{ path('feedback_index') }}">
                    <i class="bi bi-chat-square-text-fill sidebar-icon"></i> Feedback
                </a>
                <a class="nav-link {% if 'admin_users' == app.request.attributes.get('_route') %}active{% endif %}"
                   href="{{ path('admin_users') }}">
                    <i class="bi bi-shield-lock sidebar-icon"></i> Manage Users
                </a>
            </nav>
            {% endif %}

            <div class="sidebar-header">Account</div>
            <nav class="nav flex-column mb-3">
                <a class="nav-link {% if 'app_profile' in app.request.attributes.get('_route')|default('') %}active{% endif %}"
                   href="{{ path('app_profile') }}">
                    <i class="bi bi-person-gear sidebar-icon"></i> Admin
                </a>
                <a class="nav-link" href="{{ path('app_logout') }}">
                    <i class="bi bi-box-arrow-left sidebar-icon"></i> Logout
                </a>
            </nav>
        </aside>
        {% endif %}

        {# ── MAIN CONTENT ── #}
        <div class="{% if app.user %}main-content{% else %}main-content-full{% endif %}" style="padding-top: 72px;">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="{% if app.user %}px-0{% else %}container{% endif %} mt-3">
                        <div class="alert alert-{{ label }} alert-dismissible fade show">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script>
            // Sidebar toggle for mobile
            const toggle = document.getElementById('sidebarToggle');
            const sidebar = document.getElementById('sidebar');
            const backdrop = document.getElementById('sidebarBackdrop');
            if (toggle) {
                toggle.addEventListener('click', () => {
                    sidebar.classList.toggle('show');
                    backdrop.classList.toggle('show');
                });
            }
            if (backdrop) {
                backdrop.addEventListener('click', () => {
                    sidebar.classList.remove('show');
                    backdrop.classList.remove('show');
                });
            }
        </script>
    </body>
</html>
